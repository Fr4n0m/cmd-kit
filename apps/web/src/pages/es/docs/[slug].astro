---
import DocsPageContent from "../../../components/DocsPageContent.astro";
import { getDocHeadings, getDocPage, getDocSlugs, type DocSlug } from "../../../i18n/docs";
import DocsLayout from "../../../layouts/DocsLayout.astro";

export function getStaticPaths() {
  return getDocSlugs().map((slug) => ({
    params: { slug }
  }));
}

const slug = Astro.params.slug as DocSlug;
const page = getDocPage("es", slug);
const headings = getDocHeadings("es", slug);
---

<DocsLayout description={page.description} headings={headings} locale="es" title={page.title}>
  <DocsPageContent locale="es" page={page} />
</DocsLayout>
