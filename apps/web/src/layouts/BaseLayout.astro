---
import "@/styles.css";
import BrandLockup from "@/components/BrandLockup.astro";
import { GlobalPaletteIsland } from "@/components/GlobalPaletteIsland";
import Icon from "@/components/Icon.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import {
  defaultLocale,
  layoutCopy,
  localizedPath,
  swapLocalePath,
  type Locale
} from "@/i18n/site";
import { getDocsNavigation, type DocsSectionItem } from "@/i18n/docs";

interface Props {
  description: string;
  title: string;
  locale?: Locale;
  image?: string;
  docsHeadings?: DocsSectionItem[];
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { description, docsHeadings = [], image, locale = defaultLocale, structuredData, title } =
  Astro.props;
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, Astro.site ?? Astro.url).toString();
const socialImageUrl = image
  ? new URL(image, Astro.site ?? Astro.url).toString()
  : undefined;
const englishUrl = new URL(localizedPath("en", pathname === "/es" ? "/" : pathname.startsWith("/es/") ? pathname.slice(3) : pathname), Astro.site ?? Astro.url).toString();
const spanishUrl = new URL(swapLocalePath(pathname, "es"), Astro.site ?? Astro.url).toString();
const copy = layoutCopy[locale];
const docsHref = localizedPath(locale, "/docs/getting-started");
const homeHref = localizedPath(locale, "/");
const playgroundHref = localizedPath(locale, "/playground");
const customizationHref = localizedPath(locale, "/docs/customization");
const docsReactHref = localizedPath(locale, "/docs/react");
const docsVueHref = localizedPath(locale, "/docs/vue");
const docsPreactHref = localizedPath(locale, "/docs/preact");
const docsAstroHref = localizedPath(locale, "/docs/astro");
const docsCoreHref = localizedPath(locale, "/docs/core");
const docsPlaygroundHref = localizedPath(locale, "/docs/playground");
const legalPrivacyHref = localizedPath(locale, "/legal/privacy");
const legalTermsHref = localizedPath(locale, "/legal/terms");
const localeSwitchHref = swapLocalePath(pathname, locale === "en" ? "es" : "en");
const currentLanguageLabel = locale === "en" ? "EN" : "ES";
const isDocsPage = pathname.startsWith("/docs") || pathname.startsWith("/es/docs");
const isLandingPage = pathname === "/" || pathname === "/es";
const docsNavigation = isDocsPage ? getDocsNavigation(locale) : [];
const themeScript = `(function(){const storageKey='cmd-kit-theme';const forceSystem=${JSON.stringify(isLandingPage)};const root=document.documentElement;const meta=document.querySelector('meta[name="theme-color"]');const emit=(theme)=>{window.dispatchEvent(new CustomEvent('cmd-kit-theme-change',{detail:{theme}}));};const getSystem=()=>window.matchMedia('(prefers-color-scheme: light)').matches?'light':'dark';const apply=(theme)=>{root.dataset.theme=theme;root.style.colorScheme=theme;if(meta){meta.setAttribute('content',theme==='light'?'#f3f7fb':'#07111f');}emit(theme);};const stored=localStorage.getItem(storageKey);const initial=forceSystem?getSystem():(stored==='light'||stored==='dark'?stored:getSystem());apply(initial);window.__cmdKitTheme={apply,getSystem,storageKey,forceSystem};})();`;
const themeToggleScript = `(function(){const root=document.documentElement;const api=window.__cmdKitTheme;const sync=()=>{const theme=root.dataset.theme==='light'?'light':'dark';document.querySelectorAll('[data-theme-toggle]').forEach((button)=>{button.setAttribute('aria-pressed',String(theme==='light'));button.setAttribute('data-theme-current',theme);});};const toggle=()=>{const next=root.dataset.theme==='light'?'dark':'light';api.apply(next);if(!api.forceSystem){localStorage.setItem(api.storageKey,next);}sync();};document.addEventListener('click',(event)=>{const button=event.target instanceof Element?event.target.closest('[data-theme-toggle]'):null;if(button){toggle();}});const media=window.matchMedia('(prefers-color-scheme: light)');if(media&&typeof media.addEventListener==='function'){media.addEventListener('change',()=>{if(api.forceSystem||!localStorage.getItem(api.storageKey)){api.apply(api.getSystem());sync();}});}sync();})();`;
const menuScript = `(function(){const root=document.documentElement;const sync=()=>{document.querySelectorAll('[data-menu-toggle]').forEach((button)=>{const expanded=root.dataset.menuOpen==='true';button.setAttribute('aria-expanded', String(expanded));});};const close=()=>{root.dataset.menuOpen='false';sync();};const toggle=()=>{root.dataset.menuOpen=root.dataset.menuOpen==='true'?'false':'true';sync();};document.addEventListener('click',(event)=>{const target=event.target instanceof Element?event.target:null;if(!target)return;const toggleButton=target.closest('[data-menu-toggle]');if(toggleButton){toggle();return;}if(window.innerWidth>640)return;if(target.closest('.topbar-menu a')){close();return;}if(!target.closest('.topbar-inner')){close();}});document.addEventListener('keydown',(event)=>{if(event.key==='Escape'){close();}});window.addEventListener('resize',()=>{if(window.innerWidth>640){close();}});if(!root.dataset.menuOpen){root.dataset.menuOpen='false';}sync();})();`;
const localeMenuScript = `(function(){const root=document.documentElement;const sync=()=>{document.querySelectorAll('[data-locale-toggle]').forEach((button)=>{button.setAttribute('aria-expanded', String(root.dataset.localeMenuOpen==='true'));});};const close=()=>{root.dataset.localeMenuOpen='false';sync();};const toggle=()=>{root.dataset.localeMenuOpen=root.dataset.localeMenuOpen==='true'?'false':'true';sync();};document.addEventListener('click',(event)=>{const target=event.target instanceof Element?event.target:null;if(!target)return;const toggleButton=target.closest('[data-locale-toggle]');if(toggleButton){toggle();return;}if(!target.closest('.locale-switcher')){close();}});document.addEventListener('keydown',(event)=>{if(event.key==='Escape'){close();}});window.addEventListener('resize',()=>{if(window.innerWidth<=640){close();}});if(!root.dataset.localeMenuOpen){root.dataset.localeMenuOpen='false';}sync();})();`;

function isCurrentPath(target: string) {
  if (target === "/") {
    return pathname === localizedPath(locale, "/");
  }

  const localizedTarget = localizedPath(locale, target);
  return pathname === localizedTarget || pathname.startsWith(`${localizedTarget}/`);
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content={description} name="description" />
    <meta content="index, follow" name="robots" />
    <meta content="#07111f" name="theme-color" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={title} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    {socialImageUrl ? <meta content={socialImageUrl} name="twitter:image" /> : null}
    <meta content={title} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content={canonicalUrl} property="og:url" />
    {socialImageUrl ? <meta content={socialImageUrl} property="og:image" /> : null}
    <meta content={copy.brandAlt} property="og:site_name" />
    <link href="/favicon-96x96.png" rel="icon" sizes="96x96" type="image/png" />
    <link href="/favicon.svg" rel="icon" type="image/svg+xml" />
    <link href="/favicon.ico" rel="shortcut icon" />
    <link href="/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180" />
    <meta content={copy.brandAlt} name="apple-mobile-web-app-title" />
    <link href="/site.webmanifest" rel="manifest" />
    <link href={canonicalUrl} rel="canonical" />
    <link href={englishUrl} hreflang="en" rel="alternate" />
    <link href={spanishUrl} hreflang="es" rel="alternate" />
    <link href={englishUrl} hreflang="x-default" rel="alternate" />
    {
      structuredData ? (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      ) : null
    }
    <script is:inline set:html={themeScript} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-aura" aria-hidden="true"></div>
    <a class="skip-link" href="#main-content">{copy.skipToContent}</a>
    <header class="topbar">
      <div class="topbar-inner">
        <div class="topbar-primary">
          <BrandLockup current={isCurrentPath("/")} href={homeHref} locale={locale} />
          <div class="topbar-mobile-actions">
            <button
              aria-controls="site-menu"
              aria-expanded="false"
              aria-label={copy.menuToggleLabel}
              class="nav-button nav-button-utility menu-toggle"
              data-menu-toggle
              type="button"
            >
              <Icon className="button-icon menu-icon menu-icon-open" name="menu" />
              <Icon className="button-icon menu-icon menu-icon-close" name="x" />
            </button>
          </div>
        </div>
        <div class="topbar-menu" id="site-menu">
          <a class="nav-button nav-button-strong launch-button" href={playgroundHref}>
            <Icon className="button-icon" name="play" />
            <span>{copy.launchPlayground}</span>
          </a>
          <nav aria-label={copy.primaryNavigationLabel} class="topbar-nav">
            <a
              aria-current={isCurrentPath("/docs/getting-started") ? "page" : undefined}
              class="nav-button nav-button-subtle"
              href={docsHref}
            >
              {copy.docs}
            </a>
          </nav>
          {
            isDocsPage ? (
              <nav aria-label={copy.docsNavigationLabel} class="mobile-docs-nav">
                <p class="mobile-docs-nav-label">{copy.docs}</p>
                {
                  docsNavigation.map((item) => (
                    <>
                      <a
                        aria-current={isCurrentPath(item.href) ? "page" : undefined}
                        href={localizedPath(locale, item.href)}
                      >
                        {item.label}
                      </a>
                      {
                        isCurrentPath(item.href) && docsHeadings.length ? (
                          <div class="mobile-docs-subnav" data-docs-subnav>
                            {
                              docsHeadings.map((heading) => (
                                <a
                                  class="mobile-docs-subnav-link"
                                  data-docs-section-link
                                  href={`#${heading.id}`}
                                >
                                  {heading.label}
                                </a>
                              ))
                            }
                          </div>
                        ) : null
                      }
                    </>
                  ))
                }
              </nav>
            ) : null
          }
          <div class="topbar-actions">
            <div class="topbar-utilities">
              <button
                aria-label={copy.toggleTheme}
                class="nav-button nav-button-utility theme-toggle"
                data-theme-toggle
                type="button"
              >
              <Icon className="button-icon theme-icon theme-icon-sun" name="sun" />
              <Icon className="button-icon theme-icon theme-icon-moon" name="moon" />
              <span class="theme-toggle-label">
                <span class="theme-label-light">{copy.themeLight}</span>
                <span class="theme-label-dark">{copy.themeDark}</span>
              </span>
            </button>
              <div class="locale-switcher">
                <button
                  aria-controls="locale-menu"
                  aria-expanded="false"
                  aria-label={copy.selectLanguage}
                  class="nav-button nav-button-utility locale-toggle locale-toggle-desktop"
                  data-locale-toggle
                  type="button"
                >
                  <Icon className="button-icon" name="globe" />
                  <span class="locale-toggle-label">{currentLanguageLabel}</span>
                  <Icon className="button-icon locale-caret" name="triangle-down" />
                </button>
                <div class="locale-menu" id="locale-menu">
                  <a aria-current={locale === "en" ? "true" : undefined} href={englishUrl}>{copy.localeEnglish}</a>
                  <a aria-current={locale === "es" ? "true" : undefined} href={spanishUrl}>{copy.localeSpanish}</a>
                </div>
                <a
                  aria-label={copy.switchLanguage}
                  class="nav-button nav-button-utility locale-toggle locale-toggle-mobile"
                  href={localeSwitchHref}
                >
                <Icon className="button-icon" name="globe" />
                <span class="locale-toggle-label">{copy.switchLanguage}</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>
    <GlobalPaletteIsland
      customizationHref={customizationHref}
      docsAstroHref={docsAstroHref}
      docsCoreHref={docsCoreHref}
      docsGettingStartedHref={docsHref}
      docsPlaygroundHref={docsPlaygroundHref}
      docsPreactHref={docsPreactHref}
      docsReactHref={docsReactHref}
      docsVueHref={docsVueHref}
      homeHref={homeHref}
      legalPrivacyHref={legalPrivacyHref}
      legalTermsHref={legalTermsHref}
      locale={locale}
      playgroundHref={playgroundHref}
      client:load
    />
    <slot />
    <SiteFooter locale={locale} />
    <script is:inline set:html={themeToggleScript} />
    <script is:inline set:html={menuScript} />
    <script is:inline set:html={localeMenuScript} />
  </body>
</html>

