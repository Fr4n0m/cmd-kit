---
import DocsCodeBlock from "../../components/DocsCodeBlock.astro";
import DocsLayout from "../../layouts/DocsLayout.astro";

const title = "Cmd+kit | Preact";
const description =
  "Install the Preact package for Cmd+kit and configure a command palette with the same core API.";
---

<DocsLayout description={description} locale="en" title={title}>
      <p class="eyebrow">Preact</p>
      <h1>Preact Integration</h1>
      <p>
        `@cmd-kit/preact` mirrors the React-facing API while targeting Preact. It is the right
        option if you want the packaged command palette surface with a lighter runtime footprint.
      </p>

      <h2>Install</h2>
      <DocsCodeBlock code={`npm install @cmd-kit/preact preact
pnpm add @cmd-kit/preact preact
yarn add @cmd-kit/preact preact
bun add @cmd-kit/preact preact`} label="bash" lang="bash" />

      <h2>Basic usage</h2>
      <DocsCodeBlock code={`import { CommandPalette } from "@cmd-kit/preact";

const sections = [
  {
    id: "navigation",
    title: "Navigation",
    items: [{ id: "dashboard", title: "Dashboard", href: "/dashboard" }]
  }
];

export function Example() {
  return (
    <CommandPalette
      recents={{ sectionTitle: "Recent commands" }}
      sections={sections}
      shortcut="mod+k"
      title="Project commands"
    />
  );
}`} label="tsx" lang="tsx" />

      <h2>Configuration surface</h2>
      <ul>
        <li>`sections`, `items`, and `source` for static or async command data</li>
        <li>`messages` for copy overrides</li>
        <li>`theme` for visual tokens</li>
        <li>`classNames` for slot-level styling</li>
        <li>`renderers` for title, item, section title, and empty state overrides</li>
        <li>`recents` for automatic recent command tracking</li>
      </ul>

      <h2>Theme example</h2>
      <DocsCodeBlock code={`<CommandPalette
  sections={sections}
  theme={{
    accentColor: "#12b5e5",
    backgroundColor: "#0f1720",
    textColor: "#f5fbff",
    borderColor: "#264152",
    radius: "22px"
  }}
  title="Project commands"
/>`} label="tsx" lang="tsx" />
</DocsLayout>
