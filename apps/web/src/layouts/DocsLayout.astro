---
import BaseLayout from "./BaseLayout.astro";
import {
  getDocsNavigation,
  type DocsSectionItem
} from "@/i18n/docs";
import { layoutCopy, localizedPath, type Locale } from "@/i18n/site";

interface Props {
  description: string;
  headings?: DocsSectionItem[];
  title: string;
  locale: Locale;
}

const { description, headings = [], locale, title } = Astro.props;
const pathname = Astro.url.pathname;
const navigation = getDocsNavigation(locale);
const copy = layoutCopy[locale];

function normalizePath(path: string) {
  const withoutIndex = path.replace(/\/index\.html$/i, "/");

  if (withoutIndex === "/") {
    return "/";
  }

  return withoutIndex.endsWith("/") ? withoutIndex.slice(0, -1) : withoutIndex;
}

function isCurrentDocsPath(target: string) {
  const currentPath = normalizePath(pathname);
  const targetPath = normalizePath(target);
  return currentPath === targetPath;
}

function navIconName(href: string) {
  if (href.includes("/getting-started")) return "getting-started";
  if (href.includes("/react")) return "react";
  if (href.includes("/vue")) return "vue";
  if (href.includes("/preact")) return "preact";
  if (href.includes("/astro")) return "astro";
  if (href.includes("/core")) return "core";
  if (href.includes("/customization")) return "customization";
  if (href.includes("/playground")) return "playground";
  return "docs";
}
---

<BaseLayout description={description} docsHeadings={headings} locale={locale} title={title}>
  <main class="site-shell docs-shell" id="main-content" tabindex="-1">
    <aside class="docs-sidebar">
      <div class="docs-sidebar-card">
        <p class="docs-sidebar-eyebrow">{copy.docs}</p>
        <nav aria-label={copy.docsNavigationLabel} class="docs-nav">
          {
            navigation.map((item) => {
              const href = localizedPath(locale, item.href);
              const current = isCurrentDocsPath(href);
              const iconName = navIconName(item.href);

              return (
                <>
                  <a
                    aria-current={current ? "page" : undefined}
                    class="docs-nav-link"
                    href={href}
                  >
                    <span class="docs-nav-link-main">
                      <span class="docs-nav-folder-icon" aria-hidden="true">
                        {iconName === "getting-started" && <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h16"></path><path d="M12 4l8 8-8 8"></path></svg>}
                        {iconName === "react" && <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1.6"></circle><ellipse cx="12" cy="12" rx="9" ry="3.8"></ellipse><ellipse cx="12" cy="12" rx="9" ry="3.8" transform="rotate(60 12 12)"></ellipse><ellipse cx="12" cy="12" rx="9" ry="3.8" transform="rotate(120 12 12)"></ellipse></svg>}
                        {iconName === "vue" && <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l9 14 9-14"></path><path d="M7 5l5 8 5-8"></path></svg>}
                        {iconName === "preact" && <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7.8 4.5v9L12 21l-7.8-4.5v-9z"></path><path d="M12 8v8"></path></svg>}
                        {iconName === "astro" && <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 18l5-12 5 12"></path><path d="M9.5 12h5"></path></svg>}
                        {iconName === "core" && <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="3"></rect><path d="M9 9h6v6H9z"></path></svg>}
                        {iconName === "customization" && <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3M12 19v3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M2 12h3M19 12h3M4.9 19.1 7 17M17 7l2.1-2.1"></path></svg>}
                        {iconName === "playground" && <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6h8"></path><path d="M8 12h8"></path><path d="M8 18h8"></path><path d="M5 6h.01M5 12h.01M5 18h.01"></path></svg>}
                        {iconName === "docs" && <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 6h14"></path><path d="M5 12h14"></path><path d="M5 18h10"></path></svg>}
                      </span>
                      <span>{item.label}</span>
                    </span>
                  </a>
                  {
                    current && headings.length ? (
                      <div class="docs-subnav" data-docs-subnav>
                        <span class="docs-subnav-rail" aria-hidden="true"></span>
                        {
                          headings.map((heading) => (
                            <a
                              class="docs-subnav-link"
                              data-docs-section-link
                              href={`#${heading.id}`}
                            >
                              {heading.label}
                            </a>
                          ))
                        }
                      </div>
                    ) : null
                  }
                </>
              );
            })
          }
        </nav>
      </div>
    </aside>
    <article class="docs-panel">
      <slot />
    </article>
  </main>
  <script is:inline>
    (() => {
      const headingSelector = ".docs-panel h2[id]";
      const linkSelector = "[data-docs-section-link]";
      const links = Array.from(document.querySelectorAll(linkSelector));
      const headings = Array.from(document.querySelectorAll(headingSelector));
      const MANUAL_ACTIVE_LOCK_MS = 700;
      let manualActiveId = "";
      let manualActiveLockUntil = 0;

      if (!links.length || !headings.length) {
        return;
      }

      const setActive = (id) => {
        links.forEach((link) => {
          const active = link.getAttribute("href") === `#${id}`;
          link.classList.toggle("is-active", active);
          if (active) {
            link.setAttribute("aria-current", "location");
          } else {
            link.removeAttribute("aria-current");
          }
        });
      };

      const firstHeading = headings[0];
      if (firstHeading instanceof HTMLElement && firstHeading.id) {
        setActive(firstHeading.id);
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const isManualLockActive =
            manualActiveId &&
            window.performance.now() < manualActiveLockUntil;

          if (isManualLockActive) {
            return;
          }

          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible[0]?.target instanceof HTMLElement) {
            setActive(visible[0].target.id);
            return;
          }

          const passed = headings
            .filter((heading) => heading instanceof HTMLElement)
            .findLast((heading) => heading.getBoundingClientRect().top <= 180);

          if (passed instanceof HTMLElement) {
            setActive(passed.id);
          }
        },
        {
          rootMargin: "-18% 0px -58% 0px",
          threshold: [0, 0.2, 0.6, 1]
        }
      );

      headings.forEach((heading) => observer.observe(heading));

      links.forEach((link) => {
        link.addEventListener("click", () => {
          const id = link.getAttribute("href")?.slice(1);
          if (id) {
            manualActiveId = id;
            manualActiveLockUntil =
              window.performance.now() + MANUAL_ACTIVE_LOCK_MS;
            setActive(id);
          }
        });
      });
    })();
  </script>
</BaseLayout>

