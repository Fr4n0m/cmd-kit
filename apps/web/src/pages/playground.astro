---
import { Icon } from "../components/Icon";
import PlaygroundIsland from "../components/PlaygroundIsland";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "cmd+kit | Playground";
const description =
  "Dedicated playground for shaping the command palette, tuning sections and theme, and exporting real code.";
---

<BaseLayout description={description} locale="en" title={title}>
  <main class="site-shell playground-page" id="main-content" tabindex="-1">
    <section class="playground-page-hero">
      <div class="playground-page-copy">
        <span class="badge">Configurator</span>
        <h1>Work in a dedicated playground that behaves more like a tool than a landing page.</h1>
        <p>
          Edit structure, theme, nested commands, messages, and exports with room to think. The
          preview stays interactive while the generated code tracks every change in real time.
        </p>
        <div class="tech-strip" aria-label="Playground stack">
          <span class="tech-chip"><Icon className="tech-icon" name="react" /> React</span>
          <span class="tech-chip"><Icon className="tech-icon" name="vue" /> Vue</span>
          <span class="tech-chip"><Icon className="tech-icon" name="preact" /> Preact</span>
          <span class="tech-chip"><Icon className="tech-icon" name="astro" /> Astro</span>
          <span class="tech-chip"><Icon className="tech-icon" name="code" /> CSS / Tailwind</span>
        </div>
      </div>
    </section>
    <PlaygroundIsland client:load initialLanguage="en" mode="page" />
  </main>
</BaseLayout>
