---
import PlaygroundIsland from "./PlaygroundIsland";
import type { PlaygroundPageCopy } from "@/i18n/pages";
import type { Locale } from "@/i18n/site";

interface Props {
  content: PlaygroundPageCopy;
  locale: Locale;
}

const { content, locale } = Astro.props;
---

<main class="site-shell playground-page" id="main-content" tabindex="-1">
  <section class="playground-page-hero">
    <div class="playground-page-copy">
      <span class="badge">{content.badge}</span>
      <h1>{content.heading}</h1>
      <p>{content.description}</p>
      <div class="playground-page-flow">
        {content.flowSteps.map((step) => (
          <span class="playground-flow-pill">{step}</span>
        ))}
      </div>
      <a class="primary-button" href="#playground">{content.cta}</a>
    </div>
    <aside class="playground-page-stage" aria-hidden="true">
      <div class="playground-page-stage-card playground-page-stage-art">
        <img
          alt=""
          class="playground-page-stage-image playground-page-stage-image-dark"
          decoding="async"
          height="920"
          loading="eager"
          src="/playground/playground-hero-dark.webp"
          width="1200"
        />
        <img
          alt=""
          class="playground-page-stage-image playground-page-stage-image-light"
          decoding="async"
          height="920"
          loading="eager"
          src="/playground/playground-hero-light.webp"
          width="1200"
        />
      </div>
    </aside>
  </section>
  <PlaygroundIsland client:load initialLanguage={locale} mode="page" />
</main>

