---
import Icon from "./Icon.astro";
import type { Locale } from "@/i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const rootId = `hero-install-selector-${locale}`;
const isEs = locale === "es";

const labels = isEs
  ? {
      adapter: "Tecnología",
      manager: "Instalador",
      terminal: "terminal"
    }
  : {
      adapter: "Technology",
      manager: "Installer",
      terminal: "terminal"
    };

const adapters = [
  {
    id: "react",
    label: "React",
    packages: {
      bun: "bun add @cmd-kit/react",
      npm: "npm install @cmd-kit/react",
      pnpm: "pnpm add @cmd-kit/react",
      yarn: "yarn add @cmd-kit/react"
    }
  },
  {
    id: "vue",
    label: "Vue",
    packages: {
      bun: "bun add @cmd-kit/vue",
      npm: "npm install @cmd-kit/vue",
      pnpm: "pnpm add @cmd-kit/vue",
      yarn: "yarn add @cmd-kit/vue"
    }
  },
  {
    id: "preact",
    label: "Preact",
    packages: {
      bun: "bun add @cmd-kit/preact",
      npm: "npm install @cmd-kit/preact",
      pnpm: "pnpm add @cmd-kit/preact",
      yarn: "yarn add @cmd-kit/preact"
    }
  },
  {
    id: "astro",
    label: "Astro",
    packages: {
      bun: "bun add @cmd-kit/astro",
      npm: "npm install @cmd-kit/astro",
      pnpm: "pnpm add @cmd-kit/astro",
      yarn: "yarn add @cmd-kit/astro"
    }
  },
  {
    id: "core",
    label: "Core",
    packages: {
      bun: "bun add @cmd-kit/core",
      npm: "npm install @cmd-kit/core",
      pnpm: "pnpm add @cmd-kit/core",
      yarn: "yarn add @cmd-kit/core"
    }
  }
] as const;

const managers = ["npm", "pnpm", "yarn", "bun"] as const;
const defaultAdapter = "react";
const defaultManager = "npm";

function escapeHtml(value: string) {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

function formatInstallCommand(command: string) {
  const parts = command.split(" ");

  if (parts.length < 2) {
    return `<span class="install-token install-token-manager">${escapeHtml(command)}</span>`;
  }

  const [manager, action, ...packages] = parts;

  return [
    `<span class="install-token install-token-manager">${escapeHtml(manager)}</span>`,
    `<span class="install-token install-token-action">${escapeHtml(action)}</span>`,
    ...packages.map(
      (entry) => `<span class="install-token install-token-package">${escapeHtml(entry)}</span>`
    )
  ].join(" ");
}

const heroInstallScript = `(function(){const root=document.getElementById(${JSON.stringify(rootId)});if(!root)return;const packageData=${JSON.stringify(adapters)};const managers=${JSON.stringify(managers)};const command=root.querySelector('[data-hero-install=\"code\"]');const adapterLabel=root.querySelector('[data-hero-install-label=\"adapter\"]');const managerLabel=root.querySelector('[data-hero-install-label=\"manager\"]');const buttons={adapter:root.querySelector('[data-hero-install-toggle=\"adapter\"]'),manager:root.querySelector('[data-hero-install-toggle=\"manager\"]')};const menus={adapter:root.querySelector('[data-hero-install-menu=\"adapter\"]'),manager:root.querySelector('[data-hero-install-menu=\"manager\"]')};const escapeHtml=(value)=>value.replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('\"','&quot;').replaceAll(\"'\",'&#39;');const formatInstallCommand=(command)=>{const parts=command.split(' ');if(parts.length<2){return '<span class=\"install-token install-token-manager\">'+escapeHtml(command)+'</span>';}const [manager,action,...packages]=parts;return ['<span class=\"install-token install-token-manager\">'+escapeHtml(manager)+'</span>','<span class=\"install-token install-token-action\">'+escapeHtml(action)+'</span>',...packages.map((entry)=>'<span class=\"install-token install-token-package\">'+escapeHtml(entry)+'</span>')].join(' ');};let state={adapter:${JSON.stringify(defaultAdapter)},manager:${JSON.stringify(defaultManager)},open:null};const sync=()=>{const selected=packageData.find((entry)=>entry.id===state.adapter)??packageData[0];if(command instanceof HTMLElement){command.innerHTML=formatInstallCommand(selected.packages[state.manager]??selected.packages.npm);}if(adapterLabel instanceof HTMLElement){adapterLabel.textContent=selected.label;}if(managerLabel instanceof HTMLElement){managerLabel.textContent=state.manager;}['adapter','manager'].forEach((key)=>{const open=state.open===key;const button=buttons[key];const menu=menus[key];if(button instanceof HTMLElement){button.setAttribute('aria-expanded',String(open));button.classList.toggle('is-open',open);}if(menu instanceof HTMLElement){menu.hidden=!open;}root.querySelectorAll('[data-hero-install-option-group=\"'+key+'\"]').forEach((item)=>{const value=item.getAttribute('data-hero-install-option-value');const current=key==='adapter'?state.adapter:state.manager;item.setAttribute('aria-current',String(value===current));});});};const close=()=>{state.open=null;sync();};root.addEventListener('click',(event)=>{const target=event.target instanceof Element?event.target:null;if(!target)return;const toggle=target.closest('[data-hero-install-toggle]');if(toggle){const key=toggle.getAttribute('data-hero-install-toggle');state.open=state.open===key?null:key;sync();return;}const option=target.closest('[data-hero-install-option-group]');if(option){const key=option.getAttribute('data-hero-install-option-group');const value=option.getAttribute('data-hero-install-option-value');if(key==='adapter'&&packageData.some((entry)=>entry.id===value)){state.adapter=value;}if(key==='manager'&&managers.includes(value)){state.manager=value;}state.open=null;sync();return;}if(!target.closest('.install-selector-dropdown')){close();}});document.addEventListener('keydown',(event)=>{if(event.key==='Escape'){close();}});sync();})();`;
---

<section class="install-selector hero-install-selector" id={rootId}>
  <div class="install-selector-controls hero-install-controls">
    <div class="install-selector-group">
      <div class="install-selector-field install-selector-dropdown">
        <span class="install-selector-label">{labels.adapter}</span>
      <button
        aria-expanded="false"
        class="nav-button nav-button-utility dropdown-trigger install-selector-trigger"
        data-hero-install-toggle="adapter"
        type="button"
      >
        <span data-hero-install-label="adapter">React</span>
        <Icon className="button-icon locale-caret" name="triangle-down" />
      </button>
      <div class="dropdown-menu install-selector-menu" data-hero-install-menu="adapter" hidden>
        {
          adapters.map((adapter) => (
            <button
              aria-current={adapter.id === defaultAdapter ? "true" : "false"}
              class="dropdown-item install-selector-item"
              data-hero-install-option-group="adapter"
              data-hero-install-option-value={adapter.id}
              type="button"
            >
              {adapter.label}
            </button>
          ))
        }
      </div>
    </div>
    </div>
    <div class="install-selector-group">
      <div class="install-selector-field install-selector-dropdown">
        <span class="install-selector-label">{labels.manager}</span>
      <button
        aria-expanded="false"
        class="nav-button nav-button-utility dropdown-trigger install-selector-trigger"
        data-hero-install-toggle="manager"
        type="button"
      >
        <span data-hero-install-label="manager">npm</span>
        <Icon className="button-icon locale-caret" name="triangle-down" />
      </button>
      <div class="dropdown-menu install-selector-menu" data-hero-install-menu="manager" hidden>
        {
          managers.map((manager) => (
            <button
              aria-current={manager === defaultManager ? "true" : "false"}
              class="dropdown-item install-selector-item"
              data-hero-install-option-group="manager"
              data-hero-install-option-value={manager}
              type="button"
            >
              {manager}
            </button>
          ))
        }
      </div>
    </div>
    </div>
  </div>

  <div class="code-block docs-code-block install-code-block hero-install-code">
    <div class="docs-code-toolbar" aria-hidden="true">
      <div class="docs-code-dots">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <span class="docs-code-label">{labels.terminal}</span>
    </div>
    <pre class="install-code-pre"><code data-hero-install="code" set:html={formatInstallCommand(adapters[0].packages.npm)}></code></pre>
  </div>
</section>

<script is:inline set:html={heroInstallScript}></script>

