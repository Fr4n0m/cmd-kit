---
import Icon from "./Icon.astro";
import HeroPalette from "./HeroPalette.astro";
import HeroInstallSelector from "./HeroInstallSelector.astro";
import type { HomePageCopy } from "@/i18n/pages";

interface Props {
  content: HomePageCopy;
  customizationHref: string;
  docsHref: string;
  playgroundHref: string;
}

const { content, customizationHref, docsHref, playgroundHref } = Astro.props;
const localePrefix = docsHref.startsWith("/es/") ? "/es" : "";
const locale = localePrefix ? "es" : "en";
const withLocale = (path: string) => `${localePrefix}${path}`;
const homeHref = localePrefix || "/";
const docsGettingStartedHref = docsHref;
const docsReactHref = withLocale("/docs/react");
const docsVueHref = withLocale("/docs/vue");
const docsPreactHref = withLocale("/docs/preact");
const docsAstroHref = withLocale("/docs/astro");
const docsCoreHref = withLocale("/docs/core");
const docsPlaygroundHref = withLocale("/docs/playground");
const legalPrivacyHref = withLocale("/legal/privacy");
const legalTermsHref = withLocale("/legal/terms");

const homeVisuals = {
  core: {
    dark: "/home/core-dark.webp",
    light: "/home/core-light.webp"
  },
  coreEngine: {
    dark: "/home/core-engine-dark.webp",
    light: "/home/core-engine-light.webp"
  },
  logicLayer: {
    dark: "/home/logic-layer-dark.webp",
    light: "/home/logic-layer-light.webp"
  }
} as const;

const installSignals = [content.techCore, content.techAdapters, content.techNestedFlows];
---

<main class="site-shell" id="main-content" tabindex="-1">
  <section class="hero">
    <div class="hero-column hero-column-main">
      <div class="hero-copy">
        <span class="badge">{content.badge}</span>
        <p class="hero-kicker">{content.heroKicker}</p>
        <h1>{content.heroHeading}</h1>
        <p>{content.heroBody}</p>
      </div>
      <div class="hero-proof">
        <div class="hero-output-card" aria-label={content.playgroundAriaLabel}>
          <p class="hero-output-title">{content.heroStackCardTitle}</p>
          <div class="hero-output-list">
            <span class="tech-chip"><Icon className="tech-icon" name="core" /> Core</span>
            <span class="tech-chip"><Icon className="tech-icon" name="react" /> React</span>
            <span class="tech-chip"><Icon className="tech-icon" name="vue" /> Vue</span>
            <span class="tech-chip"><Icon className="tech-icon" name="preact" /> Preact</span>
            <span class="tech-chip tech-chip-astro"><Icon className="tech-icon" name="astro" /> Astro</span>
            <span class="tech-chip"><Icon className="tech-icon" name="vanilla" /> Vanilla</span>
          </div>
        </div>
        <HeroInstallSelector locale={locale} />
      </div>
    </div>
    <div class="hero-column hero-column-stage">
      <div class="hero-stage">
        <HeroPalette
          customizationHref={customizationHref}
          docsAstroHref={docsAstroHref}
          docsCoreHref={docsCoreHref}
          docsGettingStartedHref={docsGettingStartedHref}
          docsPlaygroundHref={docsPlaygroundHref}
          docsPreactHref={docsPreactHref}
          docsReactHref={docsReactHref}
          docsVueHref={docsVueHref}
          homeHref={homeHref}
          legalPrivacyHref={legalPrivacyHref}
          legalTermsHref={legalTermsHref}
          locale={locale}
          playgroundHref={playgroundHref}
          recentLabel={content.heroStageRecentLabel}
          searchPlaceholder={content.heroStageSearchPlaceholder}
          title={content.heroStageLabel}
        />
      </div>
      <div class="hero-stage-footer">
        <p class="stage-note">{content.heroStageNote}</p>
        <div class="hero-actions">
          <a class="primary-button" href={playgroundHref}>
            <Icon className="button-icon" name="play" />
            <span>{content.heroCta}</span>
          </a>
          <a class="ghost-button" href={docsHref}>
            <Icon className="button-icon" name="code" />
            <span>{content.heroDocsCta}</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="content-band content-band-overview home-story-band">
    <div class="home-storyboard">
      <article class="home-spotlight">
        <div class="home-spotlight-copy">
          <div class="card-topline">
            <span class="card-icon-wrap">
              <Icon className="card-icon" name="core" />
            </span>
            <p class="card-label">{content.overviewLargeEyebrow}</p>
          </div>
          <h2>{content.overviewLargeHeading}</h2>
          <p>{content.overviewLargeBody}</p>
          <div class="card-meta-list">
            <span class="card-meta-pill">
              <strong>{content.metricSurfaceLabel}:</strong> {content.metricSurfaceValue}
            </span>
            <span class="card-meta-pill">
              <strong>{content.metricOutputLabel}:</strong> {content.metricOutputValue}
            </span>
          </div>
        </div>
        <div class="home-spotlight-visual">
          <div class="home-media-frame home-media-frame-logic" aria-hidden="true">
            <img
              alt=""
              class="home-media home-media-dark"
              decoding="async"
              loading="lazy"
              src={homeVisuals.logicLayer.dark}
            />
            <img
              alt=""
              class="home-media home-media-light"
              decoding="async"
              loading="lazy"
              src={homeVisuals.logicLayer.light}
            />
            <div class="home-media-caption">{content.metricSurfaceValue}</div>
          </div>
        </div>
      </article>

      <div class="home-feature-grid">
        <article class="home-feature-card home-feature-card-search">
          <div class="home-feature-media">
            <img
              alt=""
              class="home-feature-image home-feature-image-dark"
              decoding="async"
              loading="lazy"
              src={homeVisuals.coreEngine.dark}
            />
            <img
              alt=""
              class="home-feature-image home-feature-image-light"
              decoding="async"
              loading="lazy"
              src={homeVisuals.coreEngine.light}
            />
            <div class="home-feature-media-caption">
              <Icon className="button-icon" name="spark" />
              <span>{content.overviewSearchEyebrow}</span>
            </div>
          </div>
          <div class="home-feature-copy">
            <div class="card-topline">
              <span class="card-icon-wrap">
                <Icon className="card-icon" name="spark" />
              </span>
              <p class="card-label">{content.overviewSearchEyebrow}</p>
            </div>
            <h2>{content.overviewSearchHeading}</h2>
            <p>{content.overviewSearchBody}</p>
          </div>
        </article>

        <article class="home-feature-card home-feature-card-react">
          <div class="home-feature-media">
            <img
              alt=""
              class="home-feature-image home-feature-image-dark"
              decoding="async"
              loading="lazy"
              src={homeVisuals.core.dark}
            />
            <img
              alt=""
              class="home-feature-image home-feature-image-light"
              decoding="async"
              loading="lazy"
              src={homeVisuals.core.light}
            />
            <div class="home-feature-media-caption">
              <Icon className="button-icon" name="react" />
              <span>{content.overviewReactEyebrow}</span>
            </div>
          </div>
          <div class="home-feature-copy">
            <div class="card-topline">
              <span class="card-icon-wrap">
                <Icon className="card-icon" name="react" />
              </span>
              <p class="card-label">{content.overviewReactEyebrow}</p>
            </div>
            <h2>{content.overviewReactHeading}</h2>
            <p>{content.overviewReactBody}</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="content-band content-band-actions home-runway-band">
    <div class="home-runway">
      <article class="home-runway-card home-runway-install">
        <div class="home-runway-install-copy">
          <div class="card-topline">
            <span class="card-icon-wrap">
              <Icon className="card-icon" name="play" />
            </span>
            <p class="card-label">{content.installEyebrow}</p>
          </div>
          <h2>{content.installHeading}</h2>
          <p>{content.installDescription}</p>
          <div class="home-runway-signals" aria-label={content.installEyebrow}>
            {installSignals.map((signal) => (
              <span class="home-signal-pill">{signal}</span>
            ))}
          </div>
        </div>
        <div class="home-runway-commands">
          {content.installCommands.map((command) => (
            <pre class="inline-code-block"><code>{command}</code></pre>
          ))}
        </div>
      </article>

      <article class="home-runway-card home-runway-docs">
        <div class="card-topline">
          <span class="card-icon-wrap">
            <Icon className="card-icon" name="code" />
          </span>
          <p class="card-label">{content.docsEyebrow}</p>
        </div>
        <h2>{content.docsHeading}</h2>
        <p>{content.docsDescription}</p>
        <div class="card-actions">
          <a class="primary-button" href={docsHref}>{content.docsCta}</a>
          <a class="ghost-button" href={customizationHref}>{content.customizationCta}</a>
        </div>
      </article>

      <article class="home-runway-card home-runway-playground">
        <div class="card-topline">
          <span class="card-icon-wrap">
            <Icon className="card-icon" name="arrow-right" />
          </span>
          <p class="card-label">{content.playgroundEyebrow}</p>
        </div>
        <h2>{content.playgroundHeading}</h2>
        <p>{content.playgroundDescription}</p>
        <div class="tech-strip" aria-label={content.playgroundAriaLabel}>
          <span class="tech-chip"><Icon className="tech-icon" name="react" /> {content.technologyNames[0]}</span>
          <span class="tech-chip"><Icon className="tech-icon" name="vue" /> {content.technologyNames[1]}</span>
          <span class="tech-chip"><Icon className="tech-icon" name="preact" /> {content.technologyNames[2]}</span>
          <span class="tech-chip"><Icon className="tech-icon" name="astro" /> {content.technologyNames[3]}</span>
          <span class="tech-chip"><Icon className="tech-icon" name="vanilla" /> {content.technologyNames[4]}</span>
        </div>
        <div class="card-actions">
          <a class="primary-button" href={playgroundHref}>
            <Icon className="button-icon" name="arrow-right" />
            <span>{content.playgroundCta}</span>
          </a>
        </div>
      </article>
    </div>
  </section>
</main>

