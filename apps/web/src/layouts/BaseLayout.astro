---
import "../styles.css";
import { Icon } from "../components/Icon";
import {
  defaultLocale,
  layoutCopy,
  localizedPath,
  swapLocalePath,
  type Locale
} from "../i18n/site";

interface Props {
  description: string;
  title: string;
  locale?: Locale;
  image?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { description, image, locale = defaultLocale, structuredData, title } =
  Astro.props;
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, Astro.site ?? Astro.url).toString();
const socialImageUrl = image
  ? new URL(image, Astro.site ?? Astro.url).toString()
  : undefined;
const englishUrl = new URL(localizedPath("en", pathname === "/es" ? "/" : pathname.startsWith("/es/") ? pathname.slice(3) : pathname), Astro.site ?? Astro.url).toString();
const spanishUrl = new URL(swapLocalePath(pathname, "es"), Astro.site ?? Astro.url).toString();
const copy = layoutCopy[locale];
const docsHref = localizedPath(locale, "/docs/getting-started");
const coreHref = localizedPath(locale, "/docs/core");
const reactHref = localizedPath(locale, "/docs/react");
const homeHref = localizedPath(locale, "/");
const playgroundHref = localizedPath(locale, "/playground");
const localeSwitchHref = swapLocalePath(pathname, locale === "en" ? "es" : "en");
const themeScript = `(function(){const storageKey='cmd-kit-theme';const root=document.documentElement;const meta=document.querySelector('meta[name="theme-color"]');const getSystem=()=>window.matchMedia('(prefers-color-scheme: light)').matches?'light':'dark';const apply=(theme)=>{root.dataset.theme=theme;root.style.colorScheme=theme; if(meta){meta.setAttribute('content', theme==='light' ? '#f3f7fb' : '#07111f');}};const stored=localStorage.getItem(storageKey);apply(stored==='light'||stored==='dark'?stored:getSystem());window.__cmdKitTheme={apply,getSystem,storageKey};})();`;
const themeToggleScript = `(function(){const root=document.documentElement;const api=window.__cmdKitTheme;const sync=()=>{const theme=root.dataset.theme==='light'?'light':'dark';document.querySelectorAll('[data-theme-toggle]').forEach((button)=>{button.setAttribute('aria-pressed', String(theme==='light')); button.setAttribute('data-theme-current', theme);});};const toggle=()=>{const next=root.dataset.theme==='light'?'dark':'light'; api.apply(next); localStorage.setItem(api.storageKey,next); sync();}; document.addEventListener('click',(event)=>{const button=event.target instanceof Element ? event.target.closest('[data-theme-toggle]') : null; if(button){toggle();}}); const media=window.matchMedia('(prefers-color-scheme: light)'); if (media && typeof media.addEventListener === 'function') {media.addEventListener('change',()=>{if(!localStorage.getItem(api.storageKey)){api.apply(api.getSystem()); sync();}});} sync();})();`;

function isCurrentPath(target: string) {
  if (target === "/") {
    return pathname === localizedPath(locale, "/");
  }

  const localizedTarget = localizedPath(locale, target);
  return pathname === localizedTarget || pathname.startsWith(`${localizedTarget}/`);
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content={description} name="description" />
    <meta content="index, follow" name="robots" />
    <meta content="#07111f" name="theme-color" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={title} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    {socialImageUrl ? <meta content={socialImageUrl} name="twitter:image" /> : null}
    <meta content={title} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content={canonicalUrl} property="og:url" />
    {socialImageUrl ? <meta content={socialImageUrl} property="og:image" /> : null}
    <meta content="cmd+kit" property="og:site_name" />
    <link href="/favicon-96x96.png" rel="icon" sizes="96x96" type="image/png" />
    <link href="/favicon.svg" rel="icon" type="image/svg+xml" />
    <link href="/favicon.ico" rel="shortcut icon" />
    <link href="/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180" />
    <meta content="Cmd+Kit" name="apple-mobile-web-app-title" />
    <link href="/site.webmanifest" rel="manifest" />
    <link href={canonicalUrl} rel="canonical" />
    <link href={englishUrl} hreflang="en" rel="alternate" />
    <link href={spanishUrl} hreflang="es" rel="alternate" />
    <link href={englishUrl} hreflang="x-default" rel="alternate" />
    {
      structuredData ? (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      ) : null
    }
    <script is:inline set:html={themeScript} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-aura" aria-hidden="true"></div>
    <a class="skip-link" href="#main-content">{copy.skipToContent}</a>
    <header class="topbar">
      <div class="topbar-inner">
        <a
          aria-current={isCurrentPath("/") ? "page" : undefined}
          class="brand-link"
          href={homeHref}
        >
          <span class="brand-mark">
            <img
              alt="cmd+kit"
              class="brand-logo"
              height="44"
              src="/brand/cmd-kit-logo-light.png"
              width="44"
            />
          </span>
          <span class="brand-copy">
            <strong>cmd+kit</strong>
            <span>{copy.productLabel}</span>
          </span>
        </a>
        <nav aria-label="Primary" class="topbar-nav">
          <a
            aria-current={isCurrentPath("/docs/getting-started") ? "page" : undefined}
            href={docsHref}
          >
            {copy.docs}
          </a>
          <a
            aria-current={isCurrentPath("/docs/core") ? "page" : undefined}
            href={coreHref}
          >
            {copy.core}
          </a>
          <a
            aria-current={isCurrentPath("/playground") ? "page" : undefined}
            href={playgroundHref}
          >
            {copy.playground}
          </a>
        </nav>
        <div class="topbar-actions">
          <a class="nav-button" href={reactHref}>
            <Icon className="button-icon" name="react" />
            <span>{copy.react}</span>
          </a>
          <button
            aria-label={copy.toggleTheme}
            class="nav-button theme-toggle"
            data-theme-toggle
            type="button"
          >
            <Icon className="button-icon theme-icon theme-icon-sun" name="sun" />
            <Icon className="button-icon theme-icon theme-icon-moon" name="moon" />
            <span class="theme-toggle-label">
              <span class="theme-label-light">{copy.themeLight}</span>
              <span class="theme-label-dark">{copy.themeDark}</span>
            </span>
          </button>
          <a class="nav-button" href={localeSwitchHref}>
            <Icon className="button-icon" name="globe" />
            <span>{copy.switchLanguage}</span>
          </a>
          <a class="nav-button nav-button-strong" href={playgroundHref}>
            <Icon className="button-icon" name="play" />
            <span>{copy.launchPlayground}</span>
          </a>
        </div>
      </div>
    </header>
    <slot />
    <script is:inline set:html={themeToggleScript} />
  </body>
</html>
