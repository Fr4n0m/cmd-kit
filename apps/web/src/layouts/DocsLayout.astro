---
import BaseLayout from "./BaseLayout.astro";
import {
  getDocsNavigation,
  type DocsSectionItem
} from "@/i18n/docs";
import { layoutCopy, localizedPath, type Locale } from "@/i18n/site";

interface Props {
  description: string;
  headings?: DocsSectionItem[];
  title: string;
  locale: Locale;
}

const { description, headings = [], locale, title } = Astro.props;
const pathname = Astro.url.pathname;
const navigation = getDocsNavigation(locale);
const copy = layoutCopy[locale];

function normalizePath(path: string) {
  const withoutIndex = path.replace(/\/index\.html$/i, "/");

  if (withoutIndex === "/") {
    return "/";
  }

  return withoutIndex.endsWith("/") ? withoutIndex.slice(0, -1) : withoutIndex;
}

function isCurrentDocsPath(target: string) {
  const currentPath = normalizePath(pathname);
  const targetPath = normalizePath(target);
  return currentPath === targetPath;
}
---

<BaseLayout description={description} docsHeadings={headings} locale={locale} title={title}>
  <main class="site-shell docs-shell" id="main-content" tabindex="-1">
    <aside class="docs-sidebar">
      <div class="docs-sidebar-card">
        <p class="docs-sidebar-eyebrow">{copy.docs}</p>
        <nav aria-label={copy.docsNavigationLabel} class="docs-nav">
          {
            navigation.map((item) => {
              const href = localizedPath(locale, item.href);
              const current = isCurrentDocsPath(href);

              return (
                <>
                  <a
                    aria-current={current ? "page" : undefined}
                    class="docs-nav-link"
                    href={href}
                  >
                    <span class="docs-nav-link-main">
                      <span class="docs-nav-folder-icon" aria-hidden="true">
                        <svg class="docs-folder-closed" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M3 7a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v2H3z"></path>
                          <path d="M3 11h18l-1.2 7.2a2 2 0 0 1-2 1.8H6.2a2 2 0 0 1-2-1.8z"></path>
                        </svg>
                        <svg class="docs-folder-open" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M3 7a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v1H3z"></path>
                          <path d="M3 10h18l-2 8a2 2 0 0 1-2 1.5H7a2 2 0 0 1-2-1.5z"></path>
                        </svg>
                      </span>
                      <span>{item.label}</span>
                    </span>
                  </a>
                  {
                    current && headings.length ? (
                      <div class="docs-subnav" data-docs-subnav>
                        <span class="docs-subnav-rail" aria-hidden="true"></span>
                        {
                          headings.map((heading) => (
                            <a
                              class="docs-subnav-link"
                              data-docs-section-link
                              href={`#${heading.id}`}
                            >
                              {heading.label}
                            </a>
                          ))
                        }
                      </div>
                    ) : null
                  }
                </>
              );
            })
          }
        </nav>
      </div>
    </aside>
    <article class="docs-panel">
      <slot />
    </article>
  </main>
  <script is:inline>
    (() => {
      const headingSelector = ".docs-panel h2[id]";
      const linkSelector = "[data-docs-section-link]";
      const links = Array.from(document.querySelectorAll(linkSelector));
      const headings = Array.from(document.querySelectorAll(headingSelector));
      const MANUAL_ACTIVE_LOCK_MS = 700;
      let manualActiveId = "";
      let manualActiveLockUntil = 0;

      if (!links.length || !headings.length) {
        return;
      }

      const setActive = (id) => {
        links.forEach((link) => {
          const active = link.getAttribute("href") === `#${id}`;
          link.classList.toggle("is-active", active);
          if (active) {
            link.setAttribute("aria-current", "location");
          } else {
            link.removeAttribute("aria-current");
          }
        });
      };

      const firstHeading = headings[0];
      if (firstHeading instanceof HTMLElement && firstHeading.id) {
        setActive(firstHeading.id);
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const isManualLockActive =
            manualActiveId &&
            window.performance.now() < manualActiveLockUntil;

          if (isManualLockActive) {
            return;
          }

          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible[0]?.target instanceof HTMLElement) {
            setActive(visible[0].target.id);
            return;
          }

          const passed = headings
            .filter((heading) => heading instanceof HTMLElement)
            .findLast((heading) => heading.getBoundingClientRect().top <= 180);

          if (passed instanceof HTMLElement) {
            setActive(passed.id);
          }
        },
        {
          rootMargin: "-18% 0px -58% 0px",
          threshold: [0, 0.2, 0.6, 1]
        }
      );

      headings.forEach((heading) => observer.observe(heading));

      links.forEach((link) => {
        link.addEventListener("click", () => {
          const id = link.getAttribute("href")?.slice(1);
          if (id) {
            manualActiveId = id;
            manualActiveLockUntil =
              window.performance.now() + MANUAL_ACTIVE_LOCK_MS;
            setActive(id);
          }
        });
      });
    })();
  </script>
</BaseLayout>

