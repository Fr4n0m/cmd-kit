---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const title = "cmd+kit | Personalizacion";
const description =
  "Personaliza secciones, tokens de tema, navegacion anidada y snippets en cmd+kit.";
---

<BaseLayout description={description} locale="es" title={title}>
  <main class="site-shell docs-shell" id="main-content" tabindex="-1">
    <article class="docs-panel">
      <p class="eyebrow">Personalizacion</p>
      <h1>Patrones de personalizacion</h1>
      <p>
        `cmd+kit` esta pensado para que los mismos conceptos aparezcan en la API del paquete y en
        el configurador en vivo. La superficie principal gira en torno a secciones, items,
        mensajes y tokens de tema.
      </p>

      <h2>Secciones</h2>
      <pre class="code-block"><code>{`const sections = [
  {
    id: "navigation",
    title: "Navigation",
    items: [{ id: "dashboard", title: "Dashboard", href: "/dashboard" }]
  }
];`}</code></pre>

      <h2>Navegacion anidada</h2>
      <pre class="code-block"><code>{`const sections = [
  {
    id: "actions",
    title: "Actions",
    items: [
      {
        id: "search",
        title: "Search",
        children: [
          {
            id: "scopes",
            title: "Scopes",
            items: [{ id: "docs", title: "Documentation" }]
          }
        ]
      }
    ]
  }
];`}</code></pre>

      <h2>Tokens de tema</h2>
      <pre class="code-block"><code>{`<CommandPalette
  sections={sections}
  theme={{
    accentColor: "#ff6b35",
    backgroundColor: "#101828",
    textColor: "#f8fafc",
    borderColor: "#334155",
    radius: "26px"
  }}
/>`}</code></pre>

      <h2>Helper de CSS variables</h2>
      <pre class="code-block"><code>{`import { createThemeCssText } from "@cmd-kit/core";

const css = createThemeCssText({
  accentColor: "#ff6b35",
  backgroundColor: "#101828"
});

const themeBlock = \`:root {
\${css}
}\`;`}</code></pre>

      <h2>Mensajes</h2>
      <pre class="code-block"><code>{`<CommandPalette
  sections={sections}
  messages={{
    searchPlaceholder: "Search commands...",
    noResults: "No results found."
  }}
/>`}</code></pre>

      <p>
        El playground de la home debe tratarse como la via mas rapida para montar estos patrones y
        exportar codigo inicial.
      </p>
    </article>
  </main>
</BaseLayout>
