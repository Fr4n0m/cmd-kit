---
import BrandLockup from "./BrandLockup.astro";
import Icon from "./Icon.astro";
import { layoutCopy, localizedPath, type Locale } from "@/i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = layoutCopy[locale];
const privacyHref = localizedPath(locale, "/legal/privacy");
const termsHref = localizedPath(locale, "/legal/terms");
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-brand">
      <BrandLockup href={localizedPath(locale, "/")} locale={locale} />
      <p class="site-footer-copy">{copy.footerDescription}</p>
    </div>
    <nav aria-label={copy.footerNavLabel} class="site-footer-links">
      <div class="site-footer-group">
        <p>{copy.footerLegal}</p>
        <a class="site-footer-legal-link" href={privacyHref}>{copy.footerPrivacy}</a>
        <a class="site-footer-legal-link" href={termsHref}>{copy.footerTerms}</a>
      </div>
      <div class="site-footer-group site-footer-group-featured">
        <p>{copy.footerCommunity}</p>
        <a
          class="site-footer-link-inline"
          href="https://github.com/Fr4n0m/cmd-kit"
          rel="noreferrer"
          target="_blank"
        >
          <Icon className="site-footer-link-icon" name="github" />
          <span class="site-footer-link-title">{copy.footerGithubCta}</span>
          <span class="site-footer-link-copy">{copy.footerGithubHint}</span>
        </a>
        <a
          class="site-footer-link-inline"
          href="https://buymeacoffee.com/fran11799"
          rel="noreferrer"
          target="_blank"
        >
          <Icon className="site-footer-link-icon" name="coffee" />
          <span class="site-footer-link-title">{copy.footerCoffeeCta}</span>
          <span class="site-footer-link-copy">{copy.footerCoffeeHint}</span>
        </a>
      </div>
    </nav>
    <p class="site-footer-inline-note">
      Built for developers by{" "}
      <a href="https://codebyfran.es" rel="noreferrer" target="_blank">
        Fr4n0m
      </a>
    </p>
  </div>
</footer>

