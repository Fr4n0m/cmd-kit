---
import DocsCodeBlock from "../../../components/DocsCodeBlock.astro";
import DocsLayout from "../../../layouts/DocsLayout.astro";

const title = "Cmd+kit | Preact";
const description =
  "Instala el paquete de Preact para Cmd+kit y configura una command palette con la misma API base.";
---

<DocsLayout description={description} locale="es" title={title}>
      <p class="eyebrow">Preact</p>
      <h1>Integración con Preact</h1>
      <p>
        `@cmd-kit/preact` replica la API pública de React para usar la misma surface de command
        palette sobre Preact.
      </p>

      <h2>Instalación</h2>
      <DocsCodeBlock code={`npm install @cmd-kit/preact preact
pnpm add @cmd-kit/preact preact
yarn add @cmd-kit/preact preact
bun add @cmd-kit/preact preact`} label="bash" lang="bash" />

      <h2>Uso básico</h2>
      <DocsCodeBlock code={`import { CommandPalette } from "@cmd-kit/preact";

const sections = [
  {
    id: "navigation",
    title: "Navigation",
    items: [{ id: "dashboard", title: "Dashboard", href: "/dashboard" }]
  }
];

export function Example() {
  return (
    <CommandPalette
      recents={{ sectionTitle: "Comandos recientes" }}
      sections={sections}
      shortcut="mod+k"
      title="Comandos del proyecto"
    />
  );
}`} label="tsx" lang="tsx" />

      <h2>Superficie de configuración</h2>
      <ul>
        <li>`sections`, `items` y `source`</li>
        <li>`messages` para copy específico del producto</li>
        <li>`theme` para tokens visuales</li>
        <li>`classNames` para estilos por slot</li>
        <li>`renderers` para overrides de renderizado</li>
        <li>`recents` para comandos recientes</li>
      </ul>
</DocsLayout>
