---
import { Icon } from "../components/Icon";
import { localizedPath } from "../i18n/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "cmd+kit";
const description =
  "Open source command palette toolkit with a framework-agnostic core, React bindings, and a live configurator.";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  applicationCategory: "DeveloperApplication",
  description,
  name: "cmd+kit",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  }
};
const docsHref = localizedPath("en", "/docs/getting-started");
const customizationHref = localizedPath("en", "/docs/customization");
const playgroundHref = localizedPath("en", "/playground");
---

<BaseLayout
  description={description}
  locale="en"
  structuredData={structuredData}
  title={title}
>
  <main class="site-shell" id="main-content" tabindex="-1">
    <section class="hero">
      <div class="hero-copy">
        <span class="badge">Open source command palette toolkit</span>
        <p class="hero-kicker">Headless engine. Official adapters. Production-oriented UI.</p>
        <h1>Ship a command palette that feels native to your product and predictable in code.</h1>
        <p>
          `cmd+kit` gives you a framework-agnostic command engine, official adapters, nested
          navigation, recent commands, and a playground that exports real code instead of static
          design snippets.
        </p>
        <div class="hero-actions">
          <a class="primary-button" href={playgroundHref}>
            <Icon className="button-icon" name="play" />
            <span>Open the playground</span>
          </a>
          <a class="ghost-button" href={docsHref}>
            <Icon className="button-icon" name="code" />
            <span>Start with docs</span>
          </a>
        </div>
        <div class="hero-proof">
          <div class="proof-card">
            <Icon className="proof-icon" name="core" />
            <span>Core</span>
            <strong>Framework-agnostic search, grouping, execution, recents</strong>
          </div>
          <div class="proof-card">
            <Icon className="proof-icon" name="react" />
            <span>Adapters</span>
            <strong>React, Vue, Preact, Astro islands and vanilla browser</strong>
          </div>
        </div>
      </div>
      <div class="hero-stage">
        <div class="hero-stage-card">
          <div class="stage-toolbar">
            <span class="stage-pill">Cmd / Ctrl + K</span>
            <span class="stage-pill stage-pill-muted">React first</span>
          </div>
          <div class="stage-command">
            <div class="stage-command-top">
              <span class="stage-command-title">Project commands</span>
              <span class="stage-command-meta">mod+k</span>
            </div>
            <div class="stage-search">Search commands, pages, and actions...</div>
            <div class="stage-section">
              <span class="stage-section-label">Recent</span>
              <div class="stage-item stage-item-active">
                <div>
                  <strong>Open dashboard</strong>
                  <span>Jump into the workspace overview</span>
                </div>
                <em>G D</em>
              </div>
              <div class="stage-item">
                <div>
                  <strong>Search docs</strong>
                  <span>Nested section with scoped commands</span>
                </div>
                <em>Enter</em>
              </div>
            </div>
          </div>
          <div class="stage-note">
            Astro for the shell. Interactive islands only where the product actually needs state.
          </div>
        </div>
        <div class="hero-metrics">
          <div class="metric-card">
            <span>Surface</span>
            <strong>Headless + styled</strong>
          </div>
          <div class="metric-card">
            <span>Output</span>
            <strong>React, Vue, Preact, CSS, Tailwind, JSON</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="overview-grid">
      <article class="overview-card overview-card-large">
        <p class="eyebrow">Why it exists</p>
        <h2>Most command palettes force you to choose between speed of shipping and control of the surface.</h2>
        <p>
          `cmd+kit` keeps the engine portable and typed while letting teams ship a usable default UI
          or replace it without fighting the internals.
        </p>
      </article>
      <article class="overview-card">
        <p class="eyebrow">Search</p>
        <h2>Fuzzy by default</h2>
        <p>Fast matching, grouped sections, nested pages, and recents without leaking framework code into the core.</p>
      </article>
      <article class="overview-card">
        <p class="eyebrow">React</p>
        <h2>Composable surface</h2>
        <p>Use the default UI, override renderers, or treat the hook as the integration boundary for your own command layer.</p>
      </article>
    </section>

    <section class="launch-band">
      <article class="launch-card install-panel">
        <p class="eyebrow">Install</p>
        <h2>npm packages</h2>
        <p>Start with the adapter that gets you shipping fast, then drop into the core when you need full control.</p>
        <pre class="inline-code-block"><code>{`npm install @cmd-kit/react`}</code></pre>
        <pre class="inline-code-block"><code>{`npm install @cmd-kit/core`}</code></pre>
      </article>
      <article class="launch-card">
        <p class="eyebrow">Docs</p>
        <h2>Installation, customization, release flow</h2>
        <p>
          The docs are part of the product surface, not an afterthought. They cover the adapters,
          the core, customization patterns, and release preparation.
        </p>
        <div class="hero-actions">
          <a class="primary-button" href={docsHref}>Getting started</a>
          <a class="ghost-button" href={customizationHref}>Customization</a>
        </div>
      </article>
      <article class="launch-card playground-callout">
        <p class="eyebrow">Playground</p>
        <h2>A dedicated workspace for shaping the full command surface</h2>
        <p>
          The configurator now lives on its own page so the editor, preview, and generated code can
          use the full screen and keep the hierarchy clean.
        </p>
        <div class="tech-strip" aria-label="Supported technologies">
          <span class="tech-chip"><Icon className="tech-icon" name="react" /> React</span>
          <span class="tech-chip"><Icon className="tech-icon" name="vue" /> Vue</span>
          <span class="tech-chip"><Icon className="tech-icon" name="preact" /> Preact</span>
          <span class="tech-chip"><Icon className="tech-icon" name="astro" /> Astro</span>
          <span class="tech-chip"><Icon className="tech-icon" name="vanilla" /> Vanilla</span>
        </div>
        <div class="hero-actions">
          <a class="primary-button" href={playgroundHref}>
            <Icon className="button-icon" name="arrow-right" />
            <span>Open playground</span>
          </a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
