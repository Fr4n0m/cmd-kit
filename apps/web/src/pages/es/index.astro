---
import HomePageContent from "../../components/HomePageContent.astro";
import { getHomePage } from "../../i18n/pages";
import { localizedPath } from "../../i18n/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

const locale = "es";
const content = getHomePage(locale);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  applicationCategory: "DeveloperApplication",
  description: content.metaDescription,
  name: "Cmd+kit",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  }
};
---

<BaseLayout
  description={content.description}
  locale={locale}
  structuredData={structuredData}
  title={content.title}
>
  <HomePageContent
    content={content}
    customizationHref={localizedPath(locale, "/docs/customization")}
    docsHref={localizedPath(locale, "/docs/getting-started")}
    playgroundHref={localizedPath(locale, "/playground")}
  />
</BaseLayout>
