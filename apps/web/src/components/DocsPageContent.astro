---
import DocsCodeBlock from "./DocsCodeBlock.astro";
import InstallCommandSelector from "./InstallCommandSelector.astro";
import type { DocPageData } from "@/i18n/docs";
import type { Locale } from "@/i18n/site";

interface Props {
  locale: Locale;
  page: DocPageData;
}

const { locale, page } = Astro.props;

function parseFaqItem(item: string) {
  const match = item.match(/^<strong>(.*?)<\/strong>\s*(.*)$/i);

  if (!match) {
    return {
      answer: item,
      question: item
    };
  }

  return {
    answer: match[2]?.trim() || "",
    question: match[1]?.trim() || item
  };
}
---

<p class="eyebrow">{page.eyebrow}</p>
<h1>{page.heading}</h1>
{
  page.intro.map((html) => (
    <p set:html={html}></p>
  ))
}
{
  page.sections.map((section) => (
    <>
      <h2 id={section.id}>{section.label}</h2>
      {
        section.blocks.map((block) => {
          if (block.type === "paragraph") {
            return <p set:html={block.html}></p>;
          }

          if (block.type === "list") {
            if (section.id === "faq") {
              const faqItems = block.items.map(parseFaqItem);

              return (
                <div class="docs-faq">
                  {
                    faqItems.map((entry) => (
                      <article class="docs-faq-item">
                        <p class="docs-faq-question"><span set:html={entry.question}></span></p>
                        <div class="docs-faq-answer">
                          <p><span set:html={entry.answer}></span></p>
                        </div>
                      </article>
                    ))
                  }
                </div>
              );
            }

            const ListTag = block.ordered ? "ol" : "ul";
            return (
              <ListTag>
                {
                  block.items.map((item) => (
                    <li><span set:html={item}></span></li>
                  ))
                }
              </ListTag>
            );
          }

          if (block.type === "code") {
            return <DocsCodeBlock code={block.code} label={block.label} lang={block.lang} />;
          }

          if (block.type === "image") {
            return (
              <figure class="docs-media">
                <img alt={block.alt} loading="lazy" src={block.src} />
                {block.caption ? <figcaption>{block.caption}</figcaption> : null}
              </figure>
            );
          }

          return (
            <InstallCommandSelector
              adapter={block.adapter}
              locale={locale}
              showAdapter={block.showAdapter}
              showLink={block.showLink}
            />
          );
        })
      }
    </>
  ))
}

