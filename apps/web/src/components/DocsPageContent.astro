---
import DocsCodeBlock from "./DocsCodeBlock.astro";
import InstallCommandSelector from "./InstallCommandSelector.astro";
import type { DocPageData } from "../i18n/docs";
import type { Locale } from "../i18n/site";

interface Props {
  locale: Locale;
  page: DocPageData;
}

const { locale, page } = Astro.props;
---

<p class="eyebrow">{page.eyebrow}</p>
<h1>{page.heading}</h1>
{
  page.intro.map((html) => (
    <p set:html={html}></p>
  ))
}
{
  page.sections.map((section) => (
    <>
      <h2 id={section.id}>{section.label}</h2>
      {
        section.blocks.map((block) => {
          if (block.type === "paragraph") {
            return <p set:html={block.html}></p>;
          }

          if (block.type === "list") {
            const ListTag = block.ordered ? "ol" : "ul";
            return (
              <ListTag>
                {
                  block.items.map((item) => (
                    <li><span set:html={item}></span></li>
                  ))
                }
              </ListTag>
            );
          }

          if (block.type === "code") {
            return <DocsCodeBlock code={block.code} label={block.label} lang={block.lang} />;
          }

          return (
            <InstallCommandSelector
              adapter={block.adapter}
              locale={locale}
              showAdapter={block.showAdapter}
              showLink={block.showLink}
            />
          );
        })
      }
    </>
  ))
}
