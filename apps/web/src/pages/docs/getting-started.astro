---
import { localizedPath } from "../../i18n/site";
import DocsCodeBlock from "../../components/DocsCodeBlock.astro";
import InstallCommandSelector from "../../components/InstallCommandSelector.astro";
import DocsLayout from "../../layouts/DocsLayout.astro";

const title = "Cmd+kit | Getting Started";
const description =
  "Install Cmd+kit from npm, choose the right adapter, and start configuring your command palette.";
const reactHref = localizedPath("en", "/docs/react");
const vueHref = localizedPath("en", "/docs/vue");
const preactHref = localizedPath("en", "/docs/preact");
const customizationHref = localizedPath("en", "/docs/customization");
const coreHref = localizedPath("en", "/docs/core");
const playgroundDocsHref = localizedPath("en", "/docs/playground");
---

<DocsLayout description={description} locale="en" title={title}>
      <p class="eyebrow">Docs</p>
      <h1>Getting Started</h1>
      <p>
        `Cmd+kit` is a command palette system distributed as npm packages. Pick the adapter that
        matches your UI stack, install it with your package manager, and configure your palette
        through typed sections, messages, theme tokens, and optional async data sources.
      </p>

      <h2>Packages</h2>
      <ul>
        <li>`@cmd-kit/react`: default React component and hook</li>
        <li>`@cmd-kit/vue`: Vue component and composable API</li>
        <li>`@cmd-kit/preact`: Preact adapter aligned with the React-facing API</li>
        <li>`@cmd-kit/core`: headless primitives for custom UIs and framework integrations</li>
      </ul>

      <h2>Install</h2>
      <InstallCommandSelector locale="en" />

      <h2>Command model</h2>
      <p>
        Every adapter uses the same command structure: sections contain items, and items can open
        links, run callbacks, or navigate into nested sections.
      </p>
      <DocsCodeBlock code={`const sections = [
  {
    id: "navigation",
    title: "Navigation",
    items: [
      { id: "home", title: "Home", href: "/" },
      { id: "settings", title: "Settings", shortcut: "G S" }
    ]
  },
  {
    id: "search",
    title: "Search",
    items: [
      {
        id: "docs",
        title: "Documentation",
        children: [
          {
            id: "guides",
            title: "Guides",
            items: [{ id: "api", title: "API reference" }]
          }
        ]
      }
    ]
  }
];`} label="ts" lang="ts" />

      <h2>Choose your adapter</h2>
      <ul>
        <li><a href={reactHref}>React</a>: best default if you want the most complete packaged UI today</li>
        <li><a href={vueHref}>Vue</a>: same command model with a Vue-first integration surface</li>
        <li><a href={preactHref}>Preact</a>: leaner runtime with an API close to React</li>
        <li><a href={coreHref}>Core</a>: headless path for your own rendering layer</li>
        <li><a href={playgroundDocsHref}>Playground</a>: guided explanation of the live configurator and export flow</li>
      </ul>

      <h2>Customization path</h2>
      <p>
        Once the base integration is working, move to <a href={customizationHref}>Customization</a>
        to style the palette, override messages, plug async sources, and adapt rendering to your
        product.
      </p>
</DocsLayout>
