{
  "name": "@cmd-kit/core",
  "version": "0.1.3",
  "description": "Framework-agnostic command palette core for cmd+kit",
  "license": "MIT",
  "homepage": "https://cmd-kit.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fr4n0m/cmd-kit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Fr4n0m/cmd-kit/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "cmdk",
    "command-palette",
    "palette",
    "search",
    "headless",
    "web"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "match-sorter": "^8.0.0"
  }
}
