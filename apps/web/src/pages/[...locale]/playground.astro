---
import PlaygroundPageContent from "../../components/PlaygroundPageContent.astro";
import { getPlaygroundPage } from "../../i18n/pages";
import { defaultLocale, secondaryLocales, type Locale } from "../../i18n/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...secondaryLocales.map((locale) => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale as Locale | undefined) ?? defaultLocale;
const content = getPlaygroundPage(locale);
---

<BaseLayout description={content.description} locale={locale} title={content.title}>
  <PlaygroundPageContent content={content} locale={locale} />
</BaseLayout>
