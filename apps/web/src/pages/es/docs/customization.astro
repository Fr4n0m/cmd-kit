---
import DocsCodeBlock from "../../../components/DocsCodeBlock.astro";
import DocsLayout from "../../../layouts/DocsLayout.astro";

const title = "Cmd+kit | Personalización";
const description =
  "Personaliza estructura de comandos, tokens de tema, copy, renderizado y fuentes asíncronas en Cmd+kit.";
const playgroundDocsHref = "/es/docs/playground";
---

<DocsLayout description={description} locale="es" title={title}>
      <p class="eyebrow">Personalización</p>
      <h1>Personalización</h1>
      <p>
        `Cmd+kit` se configura en código. La superficie principal de personalización es la propia
        estructura de comandos, seguida de mensajes, tema, renderers y fuentes asíncronas.
      </p>
      <p>
        Si quieres explorar estos ajustes con una interfaz guiada antes de llevarlos a código,
        consulta la <a href={playgroundDocsHref}>documentación del playground</a>.
      </p>

      <h2>Define secciones e items</h2>
      <DocsCodeBlock code={`const sections = [
  {
    id: "navigation",
    title: "Navigation",
    items: [
      {
        id: "dashboard",
        title: "Dashboard",
        subtitle: "Open the main workspace",
        href: "/dashboard",
        keywords: ["home", "workspace"]
      }
    ]
  }
];`} label="ts" lang="ts" />

      <h2>Navegación anidada</h2>
      <DocsCodeBlock code={`const sections = [
  {
    id: "search",
    title: "Search",
    items: [
      {
        id: "docs",
        title: "Documentation",
        children: [
          {
            id: "guides",
            title: "Guides",
            items: [{ id: "api", title: "API reference" }]
          }
        ]
      }
    ]
  }
];`} label="ts" lang="ts" />

      <h2>Tokens de tema</h2>
      <DocsCodeBlock code={`<CommandPalette
  sections={sections}
  theme={{
    accentColor: "#12b5e5",
    backgroundColor: "#0f1720",
    textColor: "#f5fbff",
    mutedColor: "#9fb4c4",
    borderColor: "#264152",
    overlayColor: "rgba(4, 9, 13, 0.64)",
    radius: "22px",
    shadow: "0 24px 80px rgba(0, 0, 0, 0.42)"
  }}
/>`} label="tsx" lang="tsx" />

      <h2>Mensajes</h2>
      <DocsCodeBlock code={`<CommandPalette
  sections={sections}
  messages={{
    searchPlaceholder: "Busca comandos",
    noResults: "No hay resultados para esta búsqueda.",
    closeLabel: "Cerrar palette"
  }}
/>`} label="tsx" lang="tsx" />

      <h2>Overrides de render y estilo</h2>
      <DocsCodeBlock code={`<CommandPalette
  classNames={{
    dialog: "palette-shell",
    item: "palette-item",
    emptyState: "palette-empty"
  }}
  renderers={{
    title: ({ activeTitle, breadcrumbs }) => (
      <span>{breadcrumbs.join(" / ") || activeTitle}</span>
    ),
    emptyState: ({ query }) => <span>Sin resultados para "{query}"</span>
  }}
  sections={sections}
/>`} label="tsx" lang="tsx" />

      <h2>Fuente asíncrona</h2>
      <DocsCodeBlock code={`<CommandPalette
  source={async () => {
    const response = await fetch("/api/commands");
    return response.json();
  }}
  title="Comandos del workspace"
/>`} label="tsx" lang="tsx" />
</DocsLayout>
