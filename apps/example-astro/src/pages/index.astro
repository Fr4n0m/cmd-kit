---
import CommandPalette from "@cmd-kit/astro/component";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>cmd+kit Astro example</title>
    <style>
      :root {
        color-scheme: dark light;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Inter, "Segoe UI", system-ui, -apple-system, sans-serif;
        color: #e9f4fb;
        background:
          radial-gradient(1200px 600px at 15% 0%, rgba(53, 215, 255, 0.12), transparent 65%),
          #07111f;
      }

      main {
        min-height: 100vh;
        padding: 2rem;
      }

      .toolbar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }

      .theme-toggle {
        border-radius: 10px;
        border: 1px solid rgba(129, 155, 174, 0.28);
        background: rgba(255, 255, 255, 0.04);
        color: #d8ecf8;
        padding: 0.5rem 0.8rem;
        cursor: pointer;
      }

      html[data-theme="light"] body {
        color: #0f1b26;
        background:
          radial-gradient(1200px 600px at 15% 0%, rgba(15, 166, 216, 0.11), transparent 65%),
          #edf4fa;
      }

      html[data-theme="light"] p {
        color: #5b748a;
      }

      html[data-theme="light"] .theme-toggle {
        border: 1px solid rgba(83, 112, 136, 0.24);
        background: rgba(255, 255, 255, 0.75);
        color: #1d3447;
      }

      h1 {
        margin: 0 0 0.5rem;
        font-size: 2rem;
      }

      p {
        margin: 0;
        color: #8fa4ba;
      }
    </style>
  </head>
  <body>
    <main>
      <div class="toolbar">
        <button class="theme-toggle" id="theme-toggle" type="button">Theme: auto</button>
      </div>
      <h1>cmd+kit Astro Example</h1>
      <p>Press Cmd/Ctrl + K to open the palette.</p>
      <CommandPalette />
    </main>
    <script>
      const root = document.documentElement;
      const button = document.getElementById("theme-toggle");
      const states = ["auto", "dark", "light"];
      let index = 0;

      const applyTheme = () => {
        const mode = states[index];
        if (mode === "auto") {
          delete root.dataset.theme;
        } else {
          root.dataset.theme = mode;
        }

        if (button instanceof HTMLButtonElement) {
          button.textContent = `Theme: ${mode}`;
        }

        window.dispatchEvent(new CustomEvent("cmd-kit-theme-change"));
      };

      button?.addEventListener("click", () => {
        index = (index + 1) % states.length;
        applyTheme();
      });

      applyTheme();
    </script>
  </body>
</html>
