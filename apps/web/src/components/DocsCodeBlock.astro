---
import { Code } from "astro:components";

interface Props {
  code: string;
  lang: string;
  label?: string;
}

const { code, lang, label = lang } = Astro.props;
---

<div class="code-block docs-code-block">
  <div class="docs-code-toolbar" aria-hidden="true">
    <div class="docs-code-dots">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <span class="docs-code-label">{label}</span>
  </div>
  <Code code={code} lang={lang} theme="github-dark" />
</div>
