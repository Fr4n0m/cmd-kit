---
import DocsCodeBlock from "../../../components/DocsCodeBlock.astro";
import DocsLayout from "../../../layouts/DocsLayout.astro";

const title = "Cmd+kit | Vue";
const description =
  "Instala el paquete de Vue para Cmd+kit y configura secciones, mensajes, tema y comandos recientes.";
---

<DocsLayout description={description} locale="es" title={title}>
      <p class="eyebrow">Vue</p>
      <h1>Integración con Vue</h1>
      <p>
        `@cmd-kit/vue` ofrece un componente `CommandPalette` y una API composable para los casos
        donde quieres controlar más directamente el estado de la palette.
      </p>

      <h2>Instalación</h2>
      <DocsCodeBlock code={`npm install @cmd-kit/vue vue
pnpm add @cmd-kit/vue vue
yarn add @cmd-kit/vue vue
bun add @cmd-kit/vue vue`} label="bash" lang="bash" />

      <h2>Uso básico</h2>
      <DocsCodeBlock code={`<script setup lang="ts">
import { CommandPalette } from "@cmd-kit/vue";

const sections = [
  {
    id: "navigation",
    title: "Navigation",
    items: [{ id: "dashboard", title: "Dashboard", href: "/dashboard" }]
  }
];
</script>

<template>
  <CommandPalette
    :recents="{ sectionTitle: 'Comandos recientes' }"
    :sections="sections"
    title="Comandos del proyecto"
  />
</template>`} label="vue" lang="vue" />

      <h2>Qué puedes configurar</h2>
      <ul>
        <li>`sections`, `items` y `source`</li>
        <li>`messages` para copy localizado o específico del producto</li>
        <li>`theme` para colores y tokens visuales</li>
        <li>`classNames` para estilos por slot</li>
        <li>`recents` para registrar comandos recientes</li>
      </ul>
</DocsLayout>
