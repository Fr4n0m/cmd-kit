---
import DocsCodeBlock from "../../components/DocsCodeBlock.astro";
import DocsLayout from "../../layouts/DocsLayout.astro";

const title = "Cmd+kit | Vue";
const description =
  "Install the Vue package for Cmd+kit and configure sections, messages, theming, and recent commands.";
---

<DocsLayout description={description} locale="en" title={title}>
      <p class="eyebrow">Vue</p>
      <h1>Vue Integration</h1>
      <p>
        `@cmd-kit/vue` provides a `CommandPalette` component plus a Vue composable for cases where
        you want to orchestrate state more directly. The data model stays aligned with the rest of
        the package family.
      </p>

      <h2>Install</h2>
      <DocsCodeBlock code={`npm install @cmd-kit/vue vue
pnpm add @cmd-kit/vue vue
yarn add @cmd-kit/vue vue
bun add @cmd-kit/vue vue`} label="bash" lang="bash" />

      <h2>Basic usage</h2>
      <DocsCodeBlock code={`<script setup lang="ts">
import { CommandPalette } from "@cmd-kit/vue";

const sections = [
  {
    id: "navigation",
    title: "Navigation",
    items: [{ id: "dashboard", title: "Dashboard", href: "/dashboard" }]
  }
];
</script>

<template>
  <CommandPalette
    :recents="{ sectionTitle: 'Recent commands' }"
    :sections="sections"
    title="Project commands"
  />
</template>`} label="vue" lang="vue" />

      <h2>What you can configure</h2>
      <ul>
        <li>`sections`, `items`, and `source`</li>
        <li>`messages` for localized or product-specific copy</li>
        <li>`theme` for palette color and surface tokens</li>
        <li>`classNames` for slot-level styling hooks</li>
        <li>`recents` for automatic recent command tracking</li>
      </ul>

      <h2>Messages example</h2>
      <DocsCodeBlock code={`<CommandPalette
  :messages="{
    searchPlaceholder: 'Search docs, pages, or actions',
    noResults: 'No matching command found.',
    closeLabel: 'Close command palette'
  }"
  :sections="sections"
  title="Project commands"
/>`} label="vue" lang="vue" />
</DocsLayout>
