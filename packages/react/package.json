{
  "name": "@cmd-kit/react",
  "version": "0.1.3",
  "description": "React bindings for cmd+kit",
  "license": "MIT",
  "homepage": "https://cmd-kit.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fr4n0m/cmd-kit.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Fr4n0m/cmd-kit/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "cmdk",
    "command-palette",
    "react",
    "palette",
    "search",
    "ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react,react-dom",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "typecheck": "npm run build --workspace @cmd-kit/core && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cmd-kit/core": "^0.1.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
