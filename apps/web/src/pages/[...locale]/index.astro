---
import HomePageContent from "../../components/HomePageContent.astro";
import { getHomePage } from "../../i18n/pages";
import { defaultLocale, localizedPath, secondaryLocales, type Locale } from "../../i18n/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...secondaryLocales.map((locale) => ({
      params: { locale }
    }))
  ];
}

const locale = (Astro.params.locale as Locale | undefined) ?? defaultLocale;
const content = getHomePage(locale);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  applicationCategory: "DeveloperApplication",
  description: content.metaDescription,
  name: "Cmd+kit",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  }
};
---

<BaseLayout
  description={content.description}
  locale={locale}
  structuredData={structuredData}
  title={content.title}
>
  <HomePageContent
    content={content}
    customizationHref={localizedPath(locale, "/docs/customization")}
    docsHref={localizedPath(locale, "/docs/getting-started")}
    playgroundHref={localizedPath(locale, "/playground")}
  />
</BaseLayout>
