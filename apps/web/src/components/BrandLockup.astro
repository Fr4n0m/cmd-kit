---
import { layoutCopy, type Locale } from "../i18n/site";

interface Props {
  current?: boolean;
  href?: string;
  locale?: Locale;
  subtitle?: string;
  title?: string;
}

const {
  current = false,
  href = "/",
  locale = "en",
  subtitle = layoutCopy[locale].brandSubtitle,
  title = layoutCopy[locale].brandTitle
} = Astro.props;
const copy = layoutCopy[locale];
---

<a
  aria-current={current ? "page" : undefined}
  class="brand-link"
  href={href}
>
  <span class="brand-mark">
    <img
      alt={copy.brandAlt}
      class="brand-logo brand-logo-light"
      height="44"
      src="/brand/cmd-kit-logo-light.png"
      width="44"
    />
    <img
      alt=""
      aria-hidden="true"
      class="brand-logo brand-logo-dark"
      height="44"
      src="/brand/cmd-kit-logo-dark.png"
      width="44"
    />
  </span>
  <span class="brand-copy">
    <strong class="brand-title">{title}</strong>
    <span class="brand-subtitle">{subtitle}</span>
  </span>
</a>
