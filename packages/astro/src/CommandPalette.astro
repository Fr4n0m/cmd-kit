---
import type { CommandPaletteProps } from "./types";

const props = Astro.props as CommandPaletteProps;
const rootId = `cmdkit-astro-${Math.random().toString(36).slice(2, 10)}`;
const payload = JSON.stringify({
  className: props.className ?? "",
  classNames: props.classNames ?? {},
  defaultOpen: props.defaultOpen ?? false,
  items: props.items,
  messages: props.messages,
  open: props.open,
  recents: props.recents ?? false,
  sections: props.sections,
  shortcut: props.shortcut ?? "mod+k",
  source: props.source,
  theme: props.theme,
  title: props.title ?? "Command menu"
});
---

<div class="cmdkit-astro-root" id={rootId}>
  <div class="cmdkit-astro-overlay" data-slot="overlay" hidden>
    <div class="cmdkit-astro-dialog" data-slot="dialog" role="dialog" aria-modal="true">
      <div class="cmdkit-astro-header" data-slot="header">
        <div>
          <p class="cmdkit-astro-breadcrumbs" data-slot="breadcrumbs"></p>
          <p class="cmdkit-astro-title" data-slot="title">
            <button aria-label="Go back" class="cmdkit-astro-title-back" data-slot="backButton" title="Go back" type="button">←</button>
            <span data-slot="titleText"></span>
          </p>
          <p class="cmdkit-astro-caption" data-slot="caption"></p>
        </div>
        <div class="cmdkit-astro-header-actions" data-slot="headerActions">
          <button class="cmdkit-astro-close" data-slot="closeButton" type="button">
            <svg aria-hidden="true" viewBox="0 0 16 16" width="16" height="16" style="display:block">
              <path d="M4 4L12 12M12 4L4 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
            </svg>
          </button>
        </div>
      </div>
      <input class="cmdkit-astro-input" data-slot="input" type="text" />
      <div class="cmdkit-astro-list" data-slot="list"></div>
    </div>
  </div>
</div>

<script is:inline type="application/json" id={`${rootId}-payload`} set:html={payload}></script>
<script>
  import {
    createCommandSnapshot,
    createResolvedConfig,
    executeCommand,
    recordRecentCommand,
    resolveRecentCommands
  } from "@cmd-kit/core";

  const root = document.querySelector(".cmdkit-astro-root:not([data-cmdkit-initialized='true'])");
  if (!(root instanceof HTMLElement)) {
    throw new Error("Cmd+kit Astro component root not found.");
  }
  root.dataset.cmdkitInitialized = "true";
  const payloadNode = document.getElementById(`${root.id}-payload`);

  if (!payloadNode?.textContent) {
    throw new Error("Cmd+kit Astro component initialization failed.");
  }

  const props = JSON.parse(payloadNode.textContent);
  const classNames = props.classNames ?? {};
  const recents = props.recents ?? false;
  const neutralInputBackground = "rgba(255, 255, 255, 0.03)";
  const neutralLightInputBackground = "rgba(171, 189, 205, 0.16)";
  const defaultLightTheme = {
    accentColor: "#0fa6d8",
    backgroundColor: "#ffffff",
    textColor: "#0e1720",
    mutedColor: "rgba(49, 68, 84, 0.78)",
    borderColor: "rgba(83, 112, 136, 0.16)",
    overlayColor: "rgba(232, 241, 248, 0.7)",
    radius: "22px",
    shadow: "0 20px 44px rgba(40, 64, 81, 0.14)"
  };
  const defaultDarkTheme = {
    accentColor: "#35d7ff",
    backgroundColor: "#0b1116",
    textColor: "#eff7fb",
    mutedColor: "rgba(172, 192, 207, 0.74)",
    borderColor: "rgba(129, 155, 174, 0.16)",
    overlayColor: "rgba(6, 10, 14, 0.74)",
    radius: "22px",
    shadow: "0 24px 80px rgba(0, 0, 0, 0.42)"
  };
  const defaultDemoSections = [
    {
      id: "workspace",
      title: "Workspace",
      items: [
        {
          id: "demo-overview",
          title: "Overview",
          subtitle: "Open the workspace overview",
          shortcut: "mod+o"
        },
        {
          id: "demo-projects",
          title: "Projects",
          subtitle: "Jump to your active projects",
          shortcut: "mod+p"
        },
        {
          id: "demo-resources",
          title: "Resources",
          subtitle: "Guides and references for the team",
          children: [
            {
              id: "demo-resources-sections",
              title: "Resources",
              items: [
                {
                  id: "demo-guides",
                  title: "Guides",
                  subtitle: "Implementation walkthroughs"
                },
                {
                  id: "demo-api-reference",
                  title: "API reference",
                  subtitle: "Props, events, and renderers"
                },
                {
                  id: "demo-release-notes",
                  title: "Release notes",
                  subtitle: "Recent updates and breaking changes"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      id: "commands",
      title: "Commands",
      items: [
        {
          id: "demo-open-search",
          title: "Search across project",
          subtitle: "Open the global search flow",
          shortcut: "mod+shift+p"
        },
        {
          id: "demo-create-command",
          title: "Create command",
          subtitle: "Create a new command entry",
          shortcut: "mod+n"
        },
        {
          id: "demo-toggle-theme",
          title: "Toggle theme",
          subtitle: "Switch between light and dark mode",
          shortcut: "mod+j"
        },
        {
          id: "demo-settings",
          title: "Settings",
          subtitle: "Open workspace settings",
          children: [
            {
              id: "demo-settings-sections",
              title: "Settings",
              items: [
                {
                  id: "demo-profile-settings",
                  title: "Profile",
                  subtitle: "Update account details and preferences"
                },
                {
                  id: "demo-keyboard-settings",
                  title: "Keyboard shortcuts",
                  subtitle: "Customize command shortcuts"
                }
              ]
            }
          ]
        }
      ]
    }
  ];

  const overlay = root.querySelector("[data-slot='overlay']");
  const dialog = root.querySelector("[data-slot='dialog']");
  const header = root.querySelector("[data-slot='header']");
  const breadcrumbs = root.querySelector("[data-slot='breadcrumbs']");
  const title = root.querySelector("[data-slot='title']");
  const titleText = root.querySelector("[data-slot='titleText']");
  const caption = root.querySelector("[data-slot='caption']");
  const headerActions = root.querySelector("[data-slot='headerActions']");
  const closeButton = root.querySelector("[data-slot='closeButton']");
  const backButton = root.querySelector("[data-slot='backButton']");
  const input = root.querySelector("[data-slot='input']");
  const list = root.querySelector("[data-slot='list']");

  const previousFocus = { current: null };
  let query = "";
  let activeIndex = 0;
  let open = props.open ?? props.defaultOpen ?? false;
  let navigationStack = [];
  let recentRecords = [];

  const sourcePayload =
    props.source && typeof props.source === "object"
      ? props.source
      : undefined;

  const rootItems = sourcePayload?.items ?? props.items;
  const shouldUseDefaultDemoData =
    sourcePayload === undefined &&
    rootItems === undefined &&
    props.sections === undefined;
  const rootSections =
    sourcePayload?.sections ??
    props.sections ??
    (shouldUseDefaultDemoData ? defaultDemoSections : undefined);

  const rootResolved = createResolvedConfig({
    items: rootItems,
    sections: rootSections,
    messages: props.messages,
    shortcut: props.shortcut,
    theme: resolveAdaptiveTheme(props.theme)
  });

  const applyClass = (element, slot, baseClass) => {
    if (!element) return;
    const slotClass = classNames?.[slot];
    element.className = slotClass ? `${baseClass} ${slotClass}` : baseClass;
  };

  applyClass(overlay, "overlay", "cmdkit-astro-overlay");
  applyClass(dialog, "dialog", `cmdkit-astro-dialog${props.className ? ` ${props.className}` : ""}`);
  applyClass(header, "header", "cmdkit-astro-header");
  applyClass(breadcrumbs, "breadcrumbs", "cmdkit-astro-breadcrumbs");
  applyClass(title, "title", "cmdkit-astro-title");
  applyClass(caption, "caption", "cmdkit-astro-caption");
  applyClass(headerActions, "headerActions", "cmdkit-astro-header-actions");
  applyClass(closeButton, "closeButton", "cmdkit-astro-close");
  applyClass(backButton, "backButton", "cmdkit-astro-title-back");
  applyClass(input, "input", "cmdkit-astro-input");
  applyClass(list, "list", "cmdkit-astro-list");

  const isTypingTarget = (target) => {
    if (!(target instanceof HTMLElement)) {
      return false;
    }
    const tagName = target.tagName.toLowerCase();
    return (
      tagName === "input" ||
      tagName === "textarea" ||
      target.isContentEditable ||
      target.getAttribute("role") === "textbox"
    );
  };

  const matchesShortcut = (event, shortcut) => {
    const normalizedShortcut = String(shortcut ?? "").trim();

    if (!normalizedShortcut) {
      return false;
    }

    const tokens = normalizedShortcut
      .toLowerCase()
      .split("+")
      .map((token) => token.trim());
    const key = tokens.at(-1);

    if (!key || event.key.toLowerCase() !== key) {
      return false;
    }

    const expectsMod = tokens.includes("mod");
    const expectsCtrl = tokens.includes("ctrl");
    const expectsShift = tokens.includes("shift");
    const expectsAlt = tokens.includes("alt");
    const isMac = navigator.userAgent.includes("Mac");
    const modPressed = isMac ? event.metaKey : event.ctrlKey;

    return (
      (!expectsMod || modPressed) &&
      (!expectsCtrl || event.ctrlKey) &&
      (!expectsShift || event.shiftKey) &&
      (!expectsAlt || event.altKey)
    );
  };

  const prettyShortcut = (shortcut) => {
    const normalized = String(shortcut ?? "").trim();

    if (!normalized) {
      return "";
    }

    if (typeof navigator === "undefined") {
      return normalized
        .split("+")
        .map((token) => token.charAt(0).toUpperCase() + token.slice(1))
        .join(" + ");
    }

    return normalized
      .split("+")
      .map((token) => {
        if (token === "mod") {
          return navigator.userAgent.includes("Mac") ? "Cmd" : "Ctrl";
        }

        return token.charAt(0).toUpperCase() + token.slice(1);
      })
      .join(" + ");
  };

  function parseColorToRgb(color) {
    const value = String(color ?? "").trim();

    if (value.startsWith("#")) {
      const hex = value.slice(1);

      if (hex.length === 3) {
        return [
          Number.parseInt(hex[0] + hex[0], 16),
          Number.parseInt(hex[1] + hex[1], 16),
          Number.parseInt(hex[2] + hex[2], 16)
        ];
      }

      if (hex.length >= 6) {
        return [
          Number.parseInt(hex.slice(0, 2), 16),
          Number.parseInt(hex.slice(2, 4), 16),
          Number.parseInt(hex.slice(4, 6), 16)
        ];
      }
    }

    const rgbMatch = value.match(/rgba?\((\d+)\s*,\s*(\d+)\s*,\s*(\d+)/i);
    if (rgbMatch) {
      return [
        Number.parseInt(rgbMatch[1], 10),
        Number.parseInt(rgbMatch[2], 10),
        Number.parseInt(rgbMatch[3], 10)
      ];
    }

    return null;
  }

  function isLightTheme(backgroundColor) {
    const rgb = parseColorToRgb(backgroundColor);
    if (!rgb) {
      return false;
    }

    const [r, g, b] = rgb;
    const luminance = (0.2126 * r + 0.7152 * g + 0.0722 * b) / 255;
    return luminance > 0.72;
  }

  function resolveAdaptiveTheme(theme) {
    if (theme) {
      return theme;
    }

    const rootTheme = document.documentElement.dataset.theme;
    const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
    const isLight = rootTheme === "light" || (!rootTheme && prefersLight);
    return isLight ? defaultLightTheme : defaultDarkTheme;
  }

  const toSections = (items) => {
    if (!items?.length) {
      return undefined;
    }

    const groupedItems = new Map();

    for (const item of items) {
      const sectionTitle = item.section ?? "Commands";
      const current = groupedItems.get(sectionTitle) ?? [];
      current.push(item);
      groupedItems.set(sectionTitle, current);
    }

    return Array.from(groupedItems.entries()).map(([sectionTitle, sectionItems]) => ({
      id: String(sectionTitle).toLowerCase().replace(/\s+/g, "-"),
      title: sectionTitle,
      items: sectionItems
    }));
  };

  const withRecentSection = (sections, recentItems, recentsConfig, items) => {
    if (!recentItems.length || !recentsConfig) {
      return sections ?? toSections(items);
    }

    const baseSections = sections ?? toSections(items);

    if (!baseSections?.length) {
      return undefined;
    }

    const recentIds = new Set(recentItems.map((item) => item.id));
    const filteredSections = baseSections
      .map((section) => ({
        ...section,
        items: section.items.filter((item) => !recentIds.has(item.id))
      }))
      .filter((section) => section.items.length > 0);

    return [
      {
        id: "recent",
        title:
          typeof recentsConfig === "object" && recentsConfig.sectionTitle
            ? recentsConfig.sectionTitle
            : "Recent",
        items: recentItems.map((item) => ({
          ...item,
          section: undefined
        }))
      },
      ...filteredSections
    ];
  };
  const defaultBrandIconMarkup = () =>
    `<svg aria-hidden="true" viewBox="0 0 24 24" width="100%" height="100%" style="display:block">
      <rect x="2.5" y="2.5" width="19" height="19" rx="6" fill="none" stroke="currentColor" stroke-width="1.8"></rect>
      <text x="12" y="14" text-anchor="middle" fill="currentColor" font-size="7.2" font-weight="700" font-family='Inter, "Segoe UI", system-ui, -apple-system, sans-serif'>Cmd</text>
    </svg>`;

  const findItemById = (items, id) => items.find((item) => item.id === id);

  const buildRuntime = () => {
    const activeSections = navigationStack.at(-1)?.sections ?? rootSections;
    const activeTitle = navigationStack.at(-1)?.title ?? props.title;
    const recentItems = recents
      ? resolveRecentCommands(rootResolved.items, recentRecords)
      : [];

    const resolved = createResolvedConfig({
      items: navigationStack.length ? undefined : rootItems,
      sections: withRecentSection(activeSections, recentItems, recents, rootItems),
      messages: props.messages,
      shortcut: props.shortcut,
      theme: resolveAdaptiveTheme(props.theme)
    });

    const snapshot = createCommandSnapshot(resolved, query);
    const flatItems = snapshot.items.filter((item) => !item.disabled);

    if (activeIndex >= flatItems.length) {
      activeIndex = 0;
    }

    return {
      activeTitle,
      breadcrumbs: [props.title, ...navigationStack.map((entry) => entry.title)],
      canGoBack: navigationStack.length > 0,
      flatItems,
      messages: resolved.messages,
      snapshot,
      theme: resolved.theme
    };
  };

  const updateTheme = (theme) => {
    if (
      !(dialog instanceof HTMLElement) ||
      !(overlay instanceof HTMLElement) ||
      !(input instanceof HTMLInputElement)
    ) {
      return;
    }

    const light = isLightTheme(theme.backgroundColor);
    dialog.style.borderRadius = theme.radius;
    dialog.dataset.mode = light ? "light" : "dark";
    dialog.style.border = `1px solid ${theme.borderColor}`;
    dialog.style.background = theme.backgroundColor;
    dialog.style.color = theme.textColor;
    dialog.style.boxShadow = theme.shadow;
    overlay.style.background = theme.overlayColor;
    input.style.border = `1px solid ${theme.borderColor}`;
    input.style.background = light ? neutralLightInputBackground : neutralInputBackground;
    input.style.color = theme.textColor;

    for (const button of root.querySelectorAll(".cmdkit-astro-close")) {
      if (button instanceof HTMLElement) {
        button.style.width = "2.4rem";
        button.style.height = "2.4rem";
        button.style.minWidth = "2.4rem";
        button.style.minHeight = "2.4rem";
        button.style.lineHeight = "1";
        button.style.fontSize = "0";
        button.style.fontWeight = "700";
        button.style.fontFamily =
          "system-ui, -apple-system, Segoe UI, Roboto, sans-serif";
        button.style.transition =
          "background-color 160ms ease, border-color 160ms ease, transform 140ms ease";
        button.style.border = light
          ? `1px solid ${theme.borderColor}`
          : "1px solid rgba(146, 173, 194, 0.22)";
        button.style.color = light
          ? theme.mutedColor
          : "rgba(216, 232, 244, 0.92)";
        button.style.background = light
          ? "rgba(15, 166, 216, 0.05)"
          : "rgba(166, 191, 212, 0.08)";
      }
    }

    for (const button of root.querySelectorAll(".cmdkit-astro-title-back")) {
      if (button instanceof HTMLElement) {
        button.style.border = "none";
        button.style.color = theme.mutedColor;
        button.style.background = "transparent";
        button.style.opacity = "0.9";
      }
    }

    const emptyState = list?.querySelector(".cmdkit-astro-empty");
    if (emptyState instanceof HTMLElement) {
      emptyState.style.border = `1px dashed ${theme.borderColor}`;
      emptyState.style.color = theme.mutedColor;
    }
  };

  const renderList = (runtime) => {
    if (!(list instanceof HTMLElement)) {
      return;
    }

    if (!runtime.flatItems.length) {
      const emptyStateClass = classNames?.emptyState
        ? `cmdkit-astro-empty ${classNames.emptyState}`
        : "cmdkit-astro-empty";
      list.innerHTML = `<div class="${emptyStateClass}">${runtime.messages.noResults}</div>`;
      return;
    }

    let itemIndex = -1;
    const hideRepeatedSectionTitle =
      runtime.snapshot.groups.length === 1 &&
      runtime.snapshot.groups[0]?.title === runtime.activeTitle;
    const sectionsHtml = runtime.snapshot.groups
      .map((group) => {
        const sectionClass = classNames?.section
          ? `cmdkit-astro-section ${classNames.section}`
          : "cmdkit-astro-section";
        const sectionTitleClass = classNames?.sectionTitle
          ? `cmdkit-astro-section-title ${classNames.sectionTitle}`
          : "cmdkit-astro-section-title";
        const sectionItemsClass = classNames?.sectionItems
          ? `cmdkit-astro-section-items ${classNames.sectionItems}`
          : "cmdkit-astro-section-items";

        const itemsHtml = group.items
          .map((item) => {
            const isDisabled = Boolean(item.disabled);
            if (!isDisabled) {
              itemIndex += 1;
            }

            const isActive = !isDisabled && itemIndex === activeIndex;
            const itemClass = classNames?.item
              ? `cmdkit-astro-item ${classNames.item}`
              : "cmdkit-astro-item";
            const shortcut = item.shortcut
              ? `<span class="cmdkit-astro-shortcut">${prettyShortcut(item.shortcut)}</span>`
              : item.children?.length
                ? `<span class="cmdkit-astro-shortcut">Enter</span>`
                : "";
            const subtitle = item.subtitle ? `<span class="cmdkit-astro-subtitle">${item.subtitle}</span>` : "";
            const icon = item.icon ?? defaultBrandIconMarkup();
            const itemColor = isDisabled ? runtime.theme.mutedColor : runtime.theme.textColor;

            return `<button
              aria-selected="${isActive ? "true" : "false"}"
              class="${itemClass}"
              data-item-id="${item.id}"
              role="option"
              style="color: ${itemColor};"
              type="button"
              ${isDisabled ? "disabled" : ""}
            >
              <span class="cmdkit-astro-leading">
                <span class="cmdkit-astro-icon" data-active="${isActive ? "true" : "false"}">${icon}</span>
                <span>
                  <span class="cmdkit-astro-item-title">${item.title}</span>
                  ${subtitle}
                </span>
              </span>
              ${shortcut}
            </button>`;
          })
          .join("");

        return `<section class="${sectionClass}">
          <p class="${sectionTitleClass}">${hideRepeatedSectionTitle ? "" : group.title}</p>
          <div class="${sectionItemsClass}">${itemsHtml}</div>
        </section>`;
      })
      .join("");

    list.innerHTML = sectionsHtml;
  };

  const syncListMask = () => {
    if (!(list instanceof HTMLElement)) {
      return;
    }

    const scrollable = list.scrollHeight > list.clientHeight + 1;
    const hasTop = list.scrollTop > 0;
    const hasBottom = list.scrollTop + list.clientHeight < list.scrollHeight - 1;

    if (!scrollable) {
      list.style.maskImage = "none";
      list.style.webkitMaskImage = "none";
      return;
    }

    if (hasTop && hasBottom) {
      const gradient =
        "linear-gradient(to bottom, transparent 0, #000 14px, #000 calc(100% - 14px), transparent 100%)";
      list.style.maskImage = gradient;
      list.style.webkitMaskImage = gradient;
      return;
    }

    if (!hasTop && hasBottom) {
      const gradient =
        "linear-gradient(to bottom, #000 0, #000 calc(100% - 14px), transparent 100%)";
      list.style.maskImage = gradient;
      list.style.webkitMaskImage = gradient;
      return;
    }

    if (hasTop && !hasBottom) {
      const gradient =
        "linear-gradient(to bottom, transparent 0, #000 14px, #000 100%)";
      list.style.maskImage = gradient;
      list.style.webkitMaskImage = gradient;
      return;
    }

    list.style.maskImage = "none";
    list.style.webkitMaskImage = "none";
  };

  const render = () => {
    const runtime = buildRuntime();

    if (!(overlay instanceof HTMLElement) || !(input instanceof HTMLInputElement)) {
      return;
    }

    overlay.hidden = !open;
    if (!open) {
      return;
    }

    updateTheme(runtime.theme);
    input.placeholder = runtime.messages.searchPlaceholder;
    input.value = query;

    if (titleText instanceof HTMLElement) {
      titleText.textContent = runtime.activeTitle;
    }

    if (caption instanceof HTMLElement) {
      caption.textContent = `Press ${prettyShortcut(props.shortcut)} to open or close.`;
    }

    if (breadcrumbs instanceof HTMLElement) {
      breadcrumbs.textContent = runtime.canGoBack
        ? runtime.breadcrumbs.join(" / ")
        : "";
      breadcrumbs.hidden = !runtime.canGoBack;
    }

    if (backButton instanceof HTMLElement) {
      backButton.hidden = !runtime.canGoBack;
    }

    if (closeButton instanceof HTMLElement) {
      closeButton.setAttribute("aria-label", runtime.messages.closeLabel);
    }

    renderList(runtime);
    syncListMask();
  };

  const setOpenState = (nextOpen) => {
    if (nextOpen && !open) {
      previousFocus.current =
        document.activeElement instanceof HTMLElement
          ? document.activeElement
          : null;
    }

    open = nextOpen;

    if (!open) {
      query = "";
      activeIndex = 0;
      navigationStack = [];
      setTimeout(() => {
        previousFocus.current?.focus();
      }, 0);
    }

    render();
  };

  const runItem = (item) => {
    const result = executeCommand(item);

    if (result.type === "navigate") {
      navigationStack = [...navigationStack, { sections: result.sections, title: result.title }];
      query = "";
      activeIndex = 0;
      render();
      return;
    }

    if (!item || result.type === "noop") {
      return;
    }

    if (recents) {
      recentRecords = recordRecentCommand({
        current: recentRecords,
        itemId: item.id,
        limit: typeof recents === "object" ? recents.limit : undefined
      });
    }

    if (result.type === "href") {
      window.location.assign(result.href);
      setOpenState(false);
      return;
    }

    setOpenState(false);
  };

  const goBack = () => {
    navigationStack = navigationStack.slice(0, -1);
    query = "";
    activeIndex = 0;
    render();
  };

  const findMatchingShortcutItem = (items, event) =>
    items.find((item) => !item.disabled && item.shortcut && matchesShortcut(event, item.shortcut));

  window.addEventListener("keydown", (event) => {
    if (isTypingTarget(event.target)) {
      return;
    }

    const runtime = buildRuntime();
    const shortcutItem = findMatchingShortcutItem(open ? runtime.snapshot.items : rootResolved.items, event);

    if (shortcutItem) {
      event.preventDefault();
      if (!open) {
        setOpenState(true);
      }
      runItem(shortcutItem);
      return;
    }

    if (!matchesShortcut(event, props.shortcut)) {
      return;
    }

    event.preventDefault();
    setOpenState(!open);
  });

  if (!props.theme) {
    const media = window.matchMedia("(prefers-color-scheme: light)");
    const rerender = () => render();
    const observer = new MutationObserver(rerender);
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"]
    });

    media.addEventListener("change", rerender);
    window.addEventListener("cmd-kit-theme-change", rerender);
  }

  if (overlay instanceof HTMLElement) {
    overlay.addEventListener("mousedown", (event) => {
      if (event.target === overlay) {
        setOpenState(false);
      }
    });
  }

  closeButton?.addEventListener("click", () => setOpenState(false));
  closeButton?.addEventListener("mouseenter", () => {
    const runtime = buildRuntime();
    const light = isLightTheme(runtime.theme.backgroundColor);
    if (closeButton instanceof HTMLElement) {
      closeButton.style.background = light
        ? "rgba(15, 166, 216, 0.12)"
        : "rgba(166, 191, 212, 0.18)";
      closeButton.style.borderColor = light
        ? "rgba(15, 166, 216, 0.26)"
        : "rgba(146, 173, 194, 0.34)";
      closeButton.style.transform = "translateY(-1px)";
    }
  });
  closeButton?.addEventListener("mouseleave", () => {
    const runtime = buildRuntime();
    const light = isLightTheme(runtime.theme.backgroundColor);
    if (closeButton instanceof HTMLElement) {
      closeButton.style.background = light
        ? "rgba(15, 166, 216, 0.05)"
        : "rgba(166, 191, 212, 0.08)";
      closeButton.style.borderColor = light
        ? runtime.theme.borderColor
        : "rgba(146, 173, 194, 0.22)";
      closeButton.style.transform = "translateY(0)";
    }
  });
  backButton?.addEventListener("click", goBack);
  backButton?.addEventListener("mouseenter", () => {
    const runtime = buildRuntime();
    if (backButton instanceof HTMLElement) {
      backButton.style.transform = "translateY(-1px)";
      backButton.style.color = runtime.theme.textColor;
      backButton.style.opacity = "1";
    }
  });
  backButton?.addEventListener("mouseleave", () => {
    const runtime = buildRuntime();
    if (backButton instanceof HTMLElement) {
      backButton.style.transform = "translateY(0)";
      backButton.style.color = runtime.theme.mutedColor;
      backButton.style.opacity = "0.9";
    }
  });

  input?.addEventListener("input", (event) => {
    query = event.currentTarget instanceof HTMLInputElement ? event.currentTarget.value : "";
    activeIndex = 0;
    render();
  });

  input?.addEventListener("keydown", (event) => {
    const runtime = buildRuntime();

    if (event.key === "Escape") {
      event.preventDefault();
      if (runtime.canGoBack) {
        goBack();
      } else {
        setOpenState(false);
      }
      return;
    }

    if (event.key === "Backspace" && !query && runtime.canGoBack) {
      event.preventDefault();
      goBack();
      return;
    }

    if (event.key === "ArrowDown") {
      event.preventDefault();
      if (runtime.flatItems.length) {
        activeIndex = (activeIndex + 1) % runtime.flatItems.length;
        render();
      }
      return;
    }

    if (event.key === "ArrowUp") {
      event.preventDefault();
      if (runtime.flatItems.length) {
        activeIndex = (activeIndex - 1 + runtime.flatItems.length) % runtime.flatItems.length;
        render();
      }
      return;
    }

    if (event.key === "Enter") {
      event.preventDefault();
      runItem(runtime.flatItems[activeIndex]);
    }
  });

  list?.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target.closest("[data-item-id]") : null;
    const itemId = target?.getAttribute("data-item-id");
    const runtime = buildRuntime();
    const item = itemId ? findItemById(runtime.snapshot.items, itemId) : undefined;

    runItem(item);
  });

  list?.addEventListener("mousemove", (event) => {
    const target = event.target instanceof Element ? event.target.closest("[data-item-id]") : null;
    const itemId = target?.getAttribute("data-item-id");

    if (!itemId) {
      return;
    }

    const runtime = buildRuntime();
    const index = runtime.flatItems.findIndex((item) => item.id === itemId);

    if (index !== -1 && index !== activeIndex) {
      activeIndex = index;
      render();
    }
  });

  list?.addEventListener("scroll", syncListMask, { passive: true });
  window.addEventListener("resize", syncListMask);

  render();
</script>

