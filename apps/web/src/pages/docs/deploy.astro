---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "cmd+kit | Deploy";
const description =
  "Deploy the cmd+kit Astro site to Vercel and keep the docs aligned with the published npm packages.";
---

<BaseLayout description={description} title={title}>
  <main class="site-shell docs-shell">
    <article class="docs-panel">
      <p class="eyebrow">Deploy</p>
      <h1>Vercel Deployment</h1>
      <p>
        `apps/web` is an Astro app built for static output with React islands only where the
        playground needs interactivity.
      </p>

      <h2>Recommended Vercel settings</h2>
      <ul>
        <li>framework preset: `Astro`</li>
        <li>root directory: `apps/web`</li>
        <li>build command: `npm run build --workspace @cmd-kit/web`</li>
        <li>output directory: `dist`</li>
      </ul>

      <h2>Before each deploy</h2>
      <ul>
        <li>run `npm run release:check` when the deployment should match a release candidate</li>
        <li>verify the install commands still match the package names you intend to publish</li>
        <li>verify the playground exports code that matches the public package API</li>
      </ul>

      <h2>After deploy</h2>
      <ul>
        <li>smoke test the homepage, docs pages, and playground on desktop and mobile</li>
        <li>confirm the docs still point to the intended npm package names or scope</li>
        <li>keep repository, issue tracker, and homepage metadata aligned with the live site</li>
      </ul>
    </article>
  </main>
</BaseLayout>
