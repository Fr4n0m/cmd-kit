---
import DocsCodeBlock from "../../components/DocsCodeBlock.astro";
import DocsLayout from "../../layouts/DocsLayout.astro";

const title = "Cmd+kit | React";
const description =
  "Install the React package for Cmd+kit and configure sections, theming, messages, and render overrides.";
---

<DocsLayout description={description} locale="en" title={title}>
      <p class="eyebrow">React</p>
      <h1>React Integration</h1>
      <p>
        `@cmd-kit/react` ships a ready-to-use `CommandPalette` component plus the
        `useCommandPalette` hook for more customized integrations. Start with the packaged
        component, then move to hook-level composition if you need a fully custom shell.
      </p>

      <h2>Install</h2>
      <DocsCodeBlock code={`npm install @cmd-kit/react react react-dom
pnpm add @cmd-kit/react react react-dom
yarn add @cmd-kit/react react react-dom
bun add @cmd-kit/react react react-dom`} label="bash" lang="bash" />

      <h2>Basic usage</h2>
      <DocsCodeBlock code={`import { CommandPalette } from "@cmd-kit/react";

const sections = [
  {
    id: "navigation",
    title: "Navigation",
    items: [
      { id: "dashboard", title: "Dashboard", href: "/dashboard" },
      { id: "settings", title: "Settings", shortcut: "G S" }
    ]
  }
];

export function Example() {
  return (
    <CommandPalette
      recents={{ sectionTitle: "Recent commands" }}
      sections={sections}
      shortcut="mod+k"
      title="Project commands"
    />
  );
}`} label="tsx" lang="tsx" />

      <h2>Core props</h2>
      <ul>
        <li>`sections` or `items`: provide static command data</li>
        <li>`source`: load commands from an async or computed source</li>
        <li>`messages`: override placeholder, empty state, and close label copy</li>
        <li>`theme`: set palette colors, border, radius, and shadow tokens</li>
        <li>`recents`: keep a recent commands section automatically</li>
        <li>`classNames`: target internal slots with your own classes</li>
        <li>`renderers`: customize title, section title, item, and empty state rendering</li>
        <li>`open`, `defaultOpen`, `onOpenChange`: control visibility from your app state</li>
      </ul>

      <h2>Customization example</h2>
      <DocsCodeBlock code={`import { CommandPalette } from "@cmd-kit/react";

export function Example() {
  return (
    <CommandPalette
      classNames={{
        dialog: "palette-shell",
        item: "palette-item",
        emptyState: "palette-empty"
      }}
      messages={{
        searchPlaceholder: "Search actions, pages, or docs",
        noResults: "No commands match your query.",
        closeLabel: "Close command palette"
      }}
      renderers={{
        title: ({ activeTitle, breadcrumbs }) => (
          <span>{breadcrumbs.join(" / ") || activeTitle}</span>
        ),
        emptyState: ({ query }) => <span>No results for "{query}"</span>
      }}
      sections={sections}
      theme={{
        accentColor: "#12b5e5",
        backgroundColor: "#0f1720",
        textColor: "#f5fbff",
        borderColor: "#264152",
        radius: "22px"
      }}
      title="Workspace commands"
    />
  );
}`} label="tsx" lang="tsx" />

      <h2>Async source</h2>
      <DocsCodeBlock code={`<CommandPalette
  source={async () => {
    const response = await fetch("/api/commands");
    return response.json();
  }}
  title="Workspace commands"
/>`} label="tsx" lang="tsx" />
</DocsLayout>
