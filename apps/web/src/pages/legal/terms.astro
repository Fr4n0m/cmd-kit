---
import LegalPageContent from "../../components/LegalPageContent.astro";
import { getLegalPage } from "../../i18n/pages";
import BaseLayout from "../../layouts/BaseLayout.astro";

const locale = "en";
const content = getLegalPage(locale, "terms");
---

<BaseLayout description={content.description} locale={locale} title={content.title}>
  <LegalPageContent content={content} />
</BaseLayout>
