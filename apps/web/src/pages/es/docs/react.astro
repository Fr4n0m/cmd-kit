---
import DocsCodeBlock from "../../../components/DocsCodeBlock.astro";
import DocsLayout from "../../../layouts/DocsLayout.astro";

const title = "Cmd+kit | React";
const description =
  "Instala el paquete de React para Cmd+kit y configura secciones, tema, mensajes y overrides de render.";
---

<DocsLayout description={description} locale="es" title={title}>
      <p class="eyebrow">React</p>
      <h1>Integración con React</h1>
      <p>
        `@cmd-kit/react` incluye el componente `CommandPalette` y el hook `useCommandPalette` para
        integraciones más personalizadas. Empieza por el componente empaquetado y baja al hook si
        necesitas una shell propia.
      </p>

      <h2>Instalación</h2>
      <DocsCodeBlock code={`npm install @cmd-kit/react react react-dom
pnpm add @cmd-kit/react react react-dom
yarn add @cmd-kit/react react react-dom
bun add @cmd-kit/react react react-dom`} label="bash" lang="bash" />

      <h2>Uso básico</h2>
      <DocsCodeBlock code={`import { CommandPalette } from "@cmd-kit/react";

const sections = [
  {
    id: "navigation",
    title: "Navigation",
    items: [
      { id: "dashboard", title: "Dashboard", href: "/dashboard" },
      { id: "settings", title: "Settings", shortcut: "G S" }
    ]
  }
];

export function Example() {
  return (
    <CommandPalette
      recents={{ sectionTitle: "Comandos recientes" }}
      sections={sections}
      shortcut="mod+k"
      title="Comandos del proyecto"
    />
  );
}`} label="tsx" lang="tsx" />

      <h2>Props principales</h2>
      <ul>
        <li>`sections` o `items`: datos estáticos de comandos</li>
        <li>`source`: carga comandos desde una fuente asíncrona o calculada</li>
        <li>`messages`: personaliza placeholder, estado vacío y etiqueta de cierre</li>
        <li>`theme`: define colores, borde, radio y sombra</li>
        <li>`recents`: añade una sección automática de comandos recientes</li>
        <li>`classNames`: aplica clases a slots internos</li>
        <li>`renderers`: personaliza título, títulos de sección, items y estado vacío</li>
        <li>`open`, `defaultOpen`, `onOpenChange`: control de apertura desde el estado de tu app</li>
      </ul>

      <h2>Ejemplo de personalización</h2>
      <DocsCodeBlock code={`import { CommandPalette } from "@cmd-kit/react";

export function Example() {
  return (
    <CommandPalette
      classNames={{
        dialog: "palette-shell",
        item: "palette-item",
        emptyState: "palette-empty"
      }}
      messages={{
        searchPlaceholder: "Busca acciones, páginas o docs",
        noResults: "No hay comandos para esta búsqueda.",
        closeLabel: "Cerrar command palette"
      }}
      renderers={{
        title: ({ activeTitle, breadcrumbs }) => (
          <span>{breadcrumbs.join(" / ") || activeTitle}</span>
        ),
        emptyState: ({ query }) => <span>Sin resultados para "{query}"</span>
      }}
      sections={sections}
      theme={{
        accentColor: "#12b5e5",
        backgroundColor: "#0f1720",
        textColor: "#f5fbff",
        borderColor: "#264152",
        radius: "22px"
      }}
      title="Comandos del workspace"
    />
  );
}`} label="tsx" lang="tsx" />
</DocsLayout>
