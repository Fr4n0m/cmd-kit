---
import BaseLayout from "@/layouts/BaseLayout.astro";

export const prerender = false;
---

<BaseLayout locale="en" title="Cmd+kit | Admin" description="Admin panel" showFooter={false}>
  <main id="main-content" class="content-shell">
    <section class="content-card">
      <h1>Subscriptions admin</h1>
      <p>Subscriber management for cmd-kit is now handled centrally in the portfolio hub.</p>
      <a class="primary-button" href="https://www.codebyfran.es/admin/subscribers" target="_blank" rel="noopener">
        Open portfolio admin
      </a>
    </section>
  </main>
</BaseLayout>
