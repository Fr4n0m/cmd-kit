---
import { Icon } from "../../components/Icon";
import PlaygroundIsland from "../../components/PlaygroundIsland";
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "cmd+kit | Playground";
const description =
  "Playground dedicado para construir la command palette, ajustar secciones y tema, y exportar codigo real.";
---

<BaseLayout description={description} locale="es" title={title}>
  <main class="site-shell playground-page" id="main-content" tabindex="-1">
    <section class="playground-page-hero">
      <div class="playground-page-copy">
        <span class="badge">Configurador</span>
        <h1>Trabaja en un playground dedicado que se comporte mas como una herramienta que como una landing.</h1>
        <p>
          Edita estructura, tema, comandos anidados, mensajes y exports con espacio real para
          pensar. La preview sigue viva mientras el codigo generado refleja cada cambio.
        </p>
        <div class="tech-strip" aria-label="Stack del playground">
          <span class="tech-chip"><Icon className="tech-icon" name="react" /> React</span>
          <span class="tech-chip"><Icon className="tech-icon" name="vue" /> Vue</span>
          <span class="tech-chip"><Icon className="tech-icon" name="preact" /> Preact</span>
          <span class="tech-chip"><Icon className="tech-icon" name="astro" /> Astro</span>
          <span class="tech-chip"><Icon className="tech-icon" name="code" /> CSS / Tailwind</span>
        </div>
      </div>
    </section>
    <PlaygroundIsland client:load initialLanguage="es" mode="page" />
  </main>
</BaseLayout>
