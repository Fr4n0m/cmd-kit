---
import { PaletteDemo } from "../components/PaletteDemo";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>cmd+kit Astro Example</title>
    <style>
      :root {
        color-scheme: dark;
        background:
          radial-gradient(circle at top left, rgba(255, 107, 53, 0.18), transparent 30%),
          #020617;
        color: #f8fafc;
        font-family: "Space Grotesk", "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      main {
        width: min(960px, calc(100vw - 2rem));
        margin: 0 auto;
        padding: 4rem 0;
      }

      .hero {
        padding: 2rem;
        border-radius: 28px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(15, 23, 42, 0.78);
        backdrop-filter: blur(18px);
      }

      .badge {
        display: inline-flex;
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-size: 0.75rem;
        color: rgba(226, 232, 240, 0.72);
      }

      h1 {
        margin: 1rem 0 0.5rem;
        font-size: clamp(2.5rem, 8vw, 4.75rem);
        line-height: 0.95;
      }

      p {
        max-width: 54ch;
        line-height: 1.7;
        color: rgba(226, 232, 240, 0.82);
      }

      code {
        font-family: "IBM Plex Mono", "Cascadia Code", monospace;
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <span class="badge">Astro island example</span>
        <h1>Use cmd+kit inside Astro without turning the page into a SPA.</h1>
        <p>
          This example keeps the page static and hydrates only the command palette island. Press
          <code>Cmd/Ctrl + K</code> to open the palette.
        </p>
      </section>

      <PaletteDemo client:load />
    </main>
  </body>
</html>
